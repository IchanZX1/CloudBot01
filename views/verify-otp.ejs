<%- include('partials/head') %>
    <%- include('partials/nav') %>

        <style>
            #otp-inputs {
                display: grid;
                grid-template-columns: repeat(6, minmax(0, 1fr));
                gap: clamp(6px, 2vw, 10px);
            }

            #otp-inputs .otp-input {
                width: 100%;
                height: clamp(48px, 14vw, 58px);
                min-width: 0;
                padding: 0;
                color: #ffffff;
                font-size: clamp(22px, 7vw, 28px);
                line-height: 1;
                font-weight: 800;
                text-align: center;
                caret-color: #22c55e;
                border-radius: 14px;
                font-variant-numeric: tabular-nums;
                -webkit-text-fill-color: currentColor;
            }

            #otp-inputs .otp-input::selection {
                background: rgba(34, 197, 94, 0.25);
            }

            body.light-theme #otp-inputs .otp-input {
                color: #0f172a;
                background: rgba(255, 255, 255, 0.85) !important;
            }
        </style>

        <div class="min-h-screen pt-24 md:pt-32 pb-16 md:pb-20 px-4 md:px-6 flex items-center justify-center hero-gradient">
            <div class="max-w-md w-full glass p-6 md:p-10 rounded-3xl md:rounded-[40px] border border-white/10 popup-float text-center"
                id="verify-card">
                <div class="mb-8">
                    <div
                        class="w-12 h-12 md:w-16 md:h-16 bg-green-500 rounded-xl md:rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg shadow-green-500/20 text-black text-2xl md:text-3xl">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h2 class="text-2xl md:text-3xl font-extrabold text-white">Verifikasi <span class="text-green-500">OTP</span>
                    </h2>
                    <p class="text-xs md:text-sm text-gray-400 mt-2">
                        Masukkan kode OTP yang dikirim ke <%= verify_method==='email' ? 'alamat Email'
                            : 'nomor WhatsApp' %> Anda
                    </p>
                    <p class="text-green-500 text-sm md:text-base font-bold mt-1">
                        <%= verify_method==='email' ? email : whatsapp %>
                    </p>
                </div>

                <form id="verify-form" class="space-y-6">
                    <input type="hidden" name="email" id="user-email" value="<%= email %>">
                    <div id="otp-inputs">
                        <input type="text" inputmode="numeric" pattern="[0-9]*" autocomplete="one-time-code" maxlength="1"
                            class="otp-input glass border border-white/10 focus:border-green-500 focus:ring-2 focus:ring-green-500/20 outline-none transition-all">
                        <input type="text" inputmode="numeric" pattern="[0-9]*" autocomplete="one-time-code" maxlength="1"
                            class="otp-input glass border border-white/10 focus:border-green-500 focus:ring-2 focus:ring-green-500/20 outline-none transition-all">
                        <input type="text" inputmode="numeric" pattern="[0-9]*" autocomplete="one-time-code" maxlength="1"
                            class="otp-input glass border border-white/10 focus:border-green-500 focus:ring-2 focus:ring-green-500/20 outline-none transition-all">
                        <input type="text" inputmode="numeric" pattern="[0-9]*" autocomplete="one-time-code" maxlength="1"
                            class="otp-input glass border border-white/10 focus:border-green-500 focus:ring-2 focus:ring-green-500/20 outline-none transition-all">
                        <input type="text" inputmode="numeric" pattern="[0-9]*" autocomplete="one-time-code" maxlength="1"
                            class="otp-input glass border border-white/10 focus:border-green-500 focus:ring-2 focus:ring-green-500/20 outline-none transition-all">
                        <input type="text" inputmode="numeric" pattern="[0-9]*" autocomplete="one-time-code" maxlength="1"
                            class="otp-input glass border border-white/10 focus:border-green-500 focus:ring-2 focus:ring-green-500/20 outline-none transition-all">
                    </div>

                    <button type="submit" id="btn-verify"
                        class="w-full bg-green-500 text-black py-4 rounded-2xl font-bold hover:bg-green-400 transition-all shadow-lg shadow-green-500/20">
                        Verifikasi Sekarang
                    </button>
                </form>

                <div class="mt-8">
                    <p class="text-gray-500 text-sm mb-2">Tidak menerima kode?</p>
                    <button id="btn-resend" disabled
                        class="text-green-500 font-bold hover:underline disabled:opacity-50 disabled:no-underline">
                        Kirim Ulang OTP (<span id="countdown">05:00</span>)
                    </button>
                </div>
                <input type="hidden" id="is-expired" value="<%= locals.isExpired ? 'true' : 'false' %>">
            </div>
        </div>

        

        <%- include('partials/footer') %>

        <% if (locals.warning) { %>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                setTimeout(() => {
                    showToast("<%= warning %>", "<%= locals.msgType || 'error' %>");
                }, 1000);
            });
        </script>
        <% } %>
