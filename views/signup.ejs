<%- include('partials/head') %>
    <%- include('partials/nav') %>

        <style>
            .verify-method-option input:checked + .method-card {
                border-color: rgba(34, 197, 94, 0.65);
                background: rgba(34, 197, 94, 0.10);
                box-shadow: 0 0 0 1px rgba(34, 197, 94, 0.18) inset;
            }

            .verify-method-option input:checked + .method-card p:first-child {
                color: #22c55e;
            }
        </style>

        <div class="min-h-screen flex items-center justify-center hero-gradient px-4 py-8">
            <div class="w-full max-w-4xl glass rounded-3xl border border-white/10 popup-float overflow-hidden flex" id="signup-card" style="min-height: 540px;">

                <!-- Left: Anime Image -->
                <div class="hidden md:block w-1/2 relative overflow-hidden rounded-l-3xl">
                    <img src="/img/anime-bg.jpg" alt="Character" class="w-full h-full object-cover object-top">
                    <div class="absolute inset-0 bg-gradient-to-r from-transparent to-black/40"></div>
                </div>

                <!-- Right: Form -->
                <div class="w-full md:w-1/2 p-8 md:p-10 flex flex-col justify-center">
                    <div class="mb-5">
                        <h2 class="text-3xl md:text-4xl font-extrabold text-white">Create an Account</h2>
                        <p class="text-sm text-gray-400 mt-1">Become part of the strongest generation</p>
                    </div>

                    <!-- Google Login -->
                    <a href="/auth/google"
                        class="flex items-center justify-between w-full px-4 py-3 rounded-2xl border border-white/15 glass hover:border-white/25 hover:bg-white/5 transition-all mb-4">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center">
                                <svg class="w-4 h-4" viewBox="0 0 24 24">
                                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                                    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                                </svg>
                            </div>
                            <div class="text-left">
                                <p class="text-white font-semibold text-sm leading-tight">Sign up with Google</p>
                                <p class="text-gray-400 text-xs">Akun otomatis dibuat dan langsung aktif</p>
                            </div>
                        </div>
                        <i class="bi bi-arrow-right text-gray-500"></i>
                    </a>

                    <!-- Divider -->
                    <div class="flex items-center gap-3 mb-4">
                        <div class="flex-1 h-px bg-white/10"></div>
                        <span class="text-xs text-gray-500 font-semibold uppercase tracking-widest">OR REGISTER WITH</span>
                        <div class="flex-1 h-px bg-white/10"></div>
                    </div>

                    <!-- Form -->
                    <form id="signup-form" action="/api/signup" method="POST" class="space-y-3">
                        <!-- Username -->
                        <div class="relative">
                            <i class="bi bi-person-badge absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 text-sm"></i>
                            <input type="text" name="username" required
                                class="auth-input w-full py-3.5 pl-11 pr-4 rounded-xl text-sm"
                                placeholder="USERNAME  •  6-12 characters">
                        </div>
                        <!-- Email -->
                        <div class="relative">
                            <i class="bi bi-envelope absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 text-sm"></i>
                            <input type="email" name="email" required
                                class="auth-input w-full py-3.5 pl-11 pr-4 rounded-xl text-sm"
                                placeholder="EMAIL  •  example@gmail.com">
                        </div>
                        <!-- WhatsApp -->
                        <div class="relative">
                            <i class="bi bi-whatsapp absolute left-4 top-1/2 -translate-y-1/2 text-green-500 text-sm"></i>
                            <input type="tel" name="whatsapp" required
                                class="auth-input w-full py-3.5 pl-11 pr-4 rounded-xl text-sm"
                                placeholder="WHATSAPP  •  62812xxxx">
                        </div>
                        <!-- Password -->
                        <div class="relative">
                            <i class="bi bi-key absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 text-sm"></i>
                            <input type="password" name="password" id="signup-password" required
                                class="auth-input w-full py-3.5 pl-11 pr-11 rounded-xl text-sm"
                                placeholder="PASSWORD  •  Create strong password">
                            <button type="button" onclick="togglePassword('signup-password', this)"
                                class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 hover:text-gray-300 transition-colors">
                                <i class="bi bi-eye-slash text-sm"></i>
                            </button>
                        </div>
                        <!-- Confirm Password -->
                        <div class="relative">
                            <i class="bi bi-shield-check absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 text-sm"></i>
                            <input type="password" name="confirm_password" id="signup-confirm" required
                                class="auth-input w-full py-3.5 pl-11 pr-11 rounded-xl text-sm"
                                placeholder="CONFIRM PASSWORD  •  Repeat password">
                            <button type="button" onclick="togglePassword('signup-confirm', this)"
                                class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 hover:text-gray-300 transition-colors">
                                <i class="bi bi-eye-slash text-sm"></i>
                            </button>
                        </div>

                        <div>
                            <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-2 ml-1">Pilih Metode OTP</p>
                            <div class="grid grid-cols-2 gap-3">
                                <label class="verify-method-option cursor-pointer">
                                    <input type="radio" name="verify_method" value="whatsapp" class="sr-only" required>
                                    <div class="method-card min-h-[58px] rounded-2xl border border-white/10 bg-white/5 px-4 py-3 flex items-center gap-3 transition-all">
                                        <i class="bi bi-whatsapp text-green-500 text-lg"></i>
                                        <div class="min-w-0">
                                            <p class="text-xs font-extrabold text-white leading-tight">WhatsApp</p>
                                            <p class="text-[10px] text-gray-500 leading-tight">Kode via chat</p>
                                        </div>
                                    </div>
                                </label>
                                <label class="verify-method-option cursor-pointer">
                                    <input type="radio" name="verify_method" value="email" class="sr-only" required checked>
                                    <div class="method-card min-h-[58px] rounded-2xl border border-white/10 bg-white/5 px-4 py-3 flex items-center gap-3 transition-all">
                                        <i class="bi bi-envelope text-blue-400 text-lg"></i>
                                        <div class="min-w-0">
                                            <p class="text-xs font-extrabold text-white leading-tight">Email</p>
                                            <p class="text-[10px] text-gray-500 leading-tight">Kode via inbox</p>
                                        </div>
                                    </div>
                                </label>
                            </div>
                        </div>

                        <button type="submit" id="btn-submit"
                            class="w-full bg-white text-black py-3.5 rounded-xl font-bold hover:bg-gray-200 transition-all text-base mt-1">
                            Create Account
                        </button>
                    </form>

                    <div class="mt-5 text-center text-sm">
                        <p class="text-gray-500">Already have an account? <a href="/login" class="text-white font-bold hover:text-green-400 transition-colors">Login</a></p>
                    </div>
                </div>
            </div>
        </div>

        <script>
        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            }
        }

        document.getElementById('signup-form')?.addEventListener('submit', async (event) => {
            event.preventDefault();

            const form = event.currentTarget;
            const submitBtn = document.getElementById('btn-submit');
            const originalText = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="bi bi-arrow-repeat animate-spin mr-2"></i>Creating...';

            try {
                const response = await fetch('/api/signup', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(Object.fromEntries(new FormData(form)))
                });
                const result = await response.json();
                if (!result.success) throw new Error(result.error || 'Gagal membuat akun.');

                const verifyForm = document.createElement('form');
                verifyForm.method = 'POST';
                verifyForm.action = '/verify-otp';

                const verifyData = result.verifyData || {};
                Object.entries({
                    email: verifyData.email || form.email.value,
                    whatsapp: verifyData.whatsapp || form.whatsapp.value,
                    method: verifyData.method || form.verify_method.value
                }).forEach(([name, value]) => {
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = name;
                    input.value = value;
                    verifyForm.appendChild(input);
                });

                document.body.appendChild(verifyForm);
                verifyForm.submit();
            } catch (err) {
                if (typeof showToast === 'function') {
                    showToast(err.message, 'error');
                } else {
                    alert(err.message);
                }
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            }
        });
        </script>

        
        <%- include('partials/footer') %>
