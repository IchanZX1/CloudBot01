<%- include('partials/head') %>
    <%- include('partials/nav') %>

        <div class="min-h-screen pt-24 md:pt-32 pb-16 md:pb-20 px-4 md:px-6 flex items-center justify-center hero-gradient">
            <div class="max-w-xl w-full glass p-6 md:p-10 rounded-3xl md:rounded-[40px] border border-white/10 popup-float" id="signup-card">
                <div class="text-center mb-8 md:mb-10">
                    <div
                        class="w-12 h-12 md:w-16 md:h-16 bg-green-500 rounded-xl md:rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg shadow-green-500/20">
                        <i class="bi bi-person-plus-fill text-black text-2xl md:text-3xl"></i>
                    </div>
                    <h2 class="text-2xl md:text-3xl font-extrabold">Buat <span class="text-green-500">Akun</span></h2>
                    <p class="text-xs md:text-sm text-gray-400 mt-2">Mulai revolusi automasi Anda di sini</p>
                </div>

                <form action="/signup" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
                    <div class="md:col-span-2">
                        <label class="block text-xs font-bold text-gray-400 mb-2 ml-1">Username</label>
                        <div class="relative">
                            <i class="bi bi-person absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 text-xs md:text-sm"></i>
                            <input type="text" name="username" required
                                class="auth-input w-full py-3.5 md:py-4 pl-11 md:pl-12 pr-4 rounded-xl md:rounded-2xl text-sm" placeholder="ZXCoder_ID">
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-400 mb-2 ml-1">Email</label>
                        <div class="relative">
                            <i class="bi bi-envelope absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 text-xs md:text-sm"></i>
                            <input type="email" name="email" required
                                class="auth-input w-full py-3.5 md:py-4 pl-11 md:pl-12 pr-4 rounded-xl md:rounded-2xl text-sm" placeholder="nama@email.com">
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-400 mb-2 ml-1">WhatsApp</label>
                        <div class="relative">
                            <i class="bi bi-whatsapp absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 text-xs md:text-sm"></i>
                            <input type="tel" name="whatsapp" required
                                class="auth-input w-full py-3.5 md:py-4 pl-11 md:pl-12 pr-4 rounded-xl md:rounded-2xl text-sm" placeholder="628123xxx">
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-400 mb-2 ml-1">Password</label>
                        <div class="relative">
                            <i class="bi bi-lock absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 text-xs md:text-sm"></i>
                            <input type="password" name="password" required
                                class="auth-input w-full py-3.5 md:py-4 pl-11 md:pl-12 pr-4 rounded-xl md:rounded-2xl text-sm" placeholder="••••••••">
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-400 mb-2 ml-1">Konfirmasi Password</label>
                        <div class="relative">
                            <i class="bi bi-shield-check absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 text-xs md:text-sm"></i>
                            <input type="password" name="confirm_password" required
                                class="auth-input w-full py-3.5 md:py-4 pl-11 md:pl-12 pr-4 rounded-xl md:rounded-2xl text-sm" placeholder="••••••••">
                        </div>
                    </div>

                    <div class="md:col-span-2 space-y-3 md:space-y-4">
                        <p class="text-xs font-bold text-gray-400 text-center uppercase tracking-widest">Metode Verifikasi</p>
                        <div class="grid grid-cols-2 gap-3 md:gap-4">
                            <label class="relative cursor-pointer group">
                                <input type="radio" name="verify_method" value="email" class="peer hidden" checked>
                                <div
                                    class="flex items-center justify-center space-x-2 py-3.5 md:py-4 rounded-xl md:rounded-2xl glass border border-white/5 peer-checked:border-green-500 peer-checked:bg-green-500/10 transition-all">
                                    <i class="bi bi-envelope-check text-lg md:text-xl"></i>
                                    <span class="font-bold text-sm md:text-base">Email</span>
                                </div>
                            </label>
                            <label class="relative cursor-pointer group">
                                <input type="radio" name="verify_method" value="whatsapp" class="peer hidden">
                                <div
                                    class="flex items-center justify-center space-x-2 py-3.5 md:py-4 rounded-xl md:rounded-2xl glass border border-white/5 peer-checked:border-green-500 peer-checked:bg-green-500/10 transition-all">
                                    <i class="bi bi-whatsapp text-lg md:text-xl"></i>
                                    <span class="font-bold text-sm md:text-base">WhatsApp</span>
                                </div>
                            </label>
                        </div>
                    </div>

                    <button type="submit" id="btn-submit"
                        class="md:col-span-2 w-full bg-green-500 text-black py-3.5 md:py-4 rounded-xl md:rounded-2xl font-bold hover:bg-green-400 transition-all shadow-lg shadow-green-500/10 mt-2 text-sm md:text-base">
                        Daftar Sekarang
                    </button>
                </form>
                <div class="mt-8 text-center text-xs md:text-sm">
                    <p class="text-gray-500">Sudah punya akun? <a href="/login"
                            class="text-green-500 font-bold hover:underline">Masuk Sekarang</a></p>
                </div>
            </div>
        </div>

        
        <%- include('partials/footer') %>