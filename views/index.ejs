<%- include('partials/head') %>
    <%- include('partials/nav') %>

        <!-- Hero Section -->
        <section class="relative pt-24 md:pt-32 pb-16 md:pb-20 px-4 md:px-6 overflow-hidden hero-gradient">
            <div class="container-responsive flex flex-col md:flex-row items-center justify-between gap-8 md:gap-12">
                <div class="flex-1 text-center md:text-left reveal">
                    <div
                        class="inline-flex items-center space-x-2 bg-green-500/10 border border-green-500/20 px-4 py-1 rounded-full text-green-500 text-xs font-bold mb-6">
                        <span class="relative flex h-2 w-2">
                            <span
                                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                        </span>
                        <span>ZXcoderID CloudBot - Online 24/7</span>
                    </div>
                    <h1 class="text-3xl md:text-7xl font-extrabold leading-tight mb-4 md:mb-6">
                        Masa Depan <br class="hidden md:block">
                        <span class="text-green-500 italic">WhatsApp Bot</span>
                    </h1>
                    <p class="text-gray-400 text-sm md:text-lg mb-8 max-w-lg mx-auto md:mx-0">
                        Kelola bisnis dan komunitas Anda dengan WhatsApp Bot tercanggih. Ringan, aman, dan fitur super
                        lengkap untuk kebutuhan modern.
                    </p>
                    <div class="flex flex-wrap justify-center md:justify-start gap-4">
                        <a href="/signup"
                            class="bg-green-500 text-black px-6 md:px-8 py-3.5 md:py-4 rounded-xl font-bold flex items-center space-x-2 hover:bg-green-400 transition-all text-sm md:text-base">
                            <i class="bi bi-rocket-takeoff-fill"></i>
                            <span>Mulai Sekarang</span>
                        </a>
                        <button
                            class="glass px-8 py-4 rounded-xl font-bold flex items-center space-x-2 hover:bg-white/10 transition-all">
                            <i class="bi bi-play-circle"></i>
                            <span>Demo Bot</span>
                        </button>
                    </div>
                </div>
                <div class="flex-1 relative reveal">
                    <div class="relative w-full aspect-square max-w-[450px] mx-auto bot-image-container">
                        <div class="absolute inset-0 bg-green-500/20 blur-[100px] rounded-full"></div>
                        <img src="/img/bot.png" alt="Bot Mascot" class="relative z-10 w-full h-full drop-shadow-[0_0_30px_rgba(34,197,94,0.3)] bot-img">
                        <div class="water-container"></div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Statistic Section -->
        <section id="statistic" class="py-12 px-4 md:px-6">
            <div class="container-responsive grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
                <div class="glass p-5 md:p-8 rounded-2xl md:rounded-3xl text-center reveal border-l-4 border-l-green-500">
                    <h3 class="text-2xl md:text-3xl font-extrabold text-green-500 mb-1 md:mb-2 text-shadow-glow">95.4k+</h3>
                    <p class="text-[8px] md:text-xs uppercase tracking-widest text-gray-500 font-bold">Pesan Terkirim</p>
                </div>
                <div class="glass p-5 md:p-8 rounded-2xl md:rounded-3xl text-center reveal border-l-4 border-l-green-500"
                    style="transition-delay: 100ms;">
                    <h3 class="text-2xl md:text-3xl font-extrabold text-green-500 mb-1 md:mb-2 text-shadow-glow">612.8k+</h3>
                    <p class="text-[8px] md:text-xs uppercase tracking-widest text-gray-500 font-bold">Pesan Diterima</p>
                </div>
                <div class="glass p-5 md:p-8 rounded-2xl md:rounded-3xl text-center reveal border-l-4 border-l-green-500"
                    style="transition-delay: 200ms;">
                    <h3 class="text-2xl md:text-3xl font-extrabold text-green-500 mb-1 md:mb-2 text-shadow-glow">12.5k+</h3>
                    <p class="text-[8px] md:text-xs uppercase tracking-widest text-gray-500 font-bold">Total User</p>
                </div>
                <div class="glass p-5 md:p-8 rounded-2xl md:rounded-3xl text-center reveal border-l-4 border-l-green-500"
                    style="transition-delay: 300ms;">
                    <h3 class="text-2xl md:text-3xl font-extrabold text-green-500 mb-1 md:mb-2 text-shadow-glow">1.8k+</h3>
                    <p class="text-[8px] md:text-xs uppercase tracking-widest text-gray-500 font-bold">Fitur Aktif</p>
                </div>
            </div>
        </section>

        <!-- Pricing Section -->
        <section id="pricing" class="py-24 px-6 relative">
            <div class="max-w-6xl mx-auto">
                <div class="text-center mb-16 reveal">
                    <h2 class="text-4xl font-extrabold mb-4">Pilih Paket <span class="text-green-500">Terbaik</span>
                        Anda</h2>
                    <p class="text-gray-400">Hemat lebih banyak dengan paket langganan jangka panjang.</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <% plans.forEach((plan, index)=> { %>
                        <div
                            class="<%= plan.name.toLowerCase() === 'basic' ? 'bg-gradient-to-b from-green-500/20 to-transparent border-2 border-green-500/50 shadow-2xl scale-105 z-10' : 'glass border border-white/5' %> p-8 rounded-[40px] flex flex-col reveal relative overflow-hidden group">
                            <% if (plan.name.toLowerCase()==='basic' ) { %>
                                <div
                                    class="absolute top-6 right-6 bg-green-500 text-black text-[10px] font-black px-3 py-1 rounded-full uppercase">
                                    Populer</div>
                                <% } %>
                                    <div class="mb-8">
                                        <h4
                                            class="text-xl font-bold mb-2 <%= plan.name.toLowerCase() === 'basic' ? 'text-green-500' : '' %>">
                                            <%= plan.name %> Plan
                                        </h4>
                                        <p class="text-gray-500 text-sm">
                                            <%= plan.name==='Trial' ? 'Coba fitur dasar secara gratis.' :
                                                (plan.name==='Basic' ? 'Cocok untuk penggunaan pribadi.'
                                                : 'Ideal untuk bisnis kecil Anda.' ) %>
                                        </p>
                                        <div class="mt-6 flex items-baseline">
                                            <% if (plan.price===0) { %>
                                                <span class="text-4xl font-extrabold">Gratis</span>
                                                <% } else { %>
                                                    <span class="text-sm font-bold text-gray-400 mr-1">Rp</span>
                                                    <span class="text-4xl font-extrabold">
                                                        <%= plan.price.toLocaleString('id-ID') %>
                                                    </span>
                                                    <span class="text-gray-500 text-sm ml-2">/ paket</span>
                                                    <% } %>
                                        </div>
                                    </div>
                                    <ul class="space-y-4 mb-10 flex-grow text-sm text-gray-400">
                                        <% plan.features.forEach(feature=> { %>
                                            <li><i class="bi bi-check2-circle text-green-500 mr-2"></i>
                                                <%= feature %>
                                            </li>
                                            <% }) %>
                                    </ul>
                                    <% if (plan.price===0) { %>
                                        <% if (user) { %>
                                            <button onclick="claimTrial()"
                                                class="w-full py-4 rounded-2xl glass font-bold hover:bg-white/10 transition-all border border-white/10">Klaim
                                                Gratis</button>
                                            <% } else { %>
                                                <button onclick="window.location.href='/signup'"
                                                    class="w-full py-4 rounded-2xl glass font-bold hover:bg-white/10 transition-all border border-white/10">Mulai
                                                    Gratis</button>
                                                <% } %>
                                                    <% } else { %>
                                                        <a href="/checkout/<%= plan._id %>"
                                                            class="w-full py-4 rounded-2xl <%= plan.name.toLowerCase() === 'basic' ? 'bg-green-500 text-black' : 'glass text-white' %> font-bold hover:opacity-90 transition-all text-center">Beli
                                                            Sekarang</a>
                                                        <% } %>
                        </div>
                        <% }) %>
                </div>
            </div>
        </section>

        <!-- Features Section (Bento Style) -->
        <section id="features" class="py-24 px-6 bg-[#080808]">
            <div class="max-w-6xl mx-auto">
                <div class="text-center mb-16 reveal">
                    <h2 class="text-4xl font-extrabold mb-4">Kenapa Memilih <span class="text-green-500">Gateway</span>
                        Kami?</h2>
                    <p class="text-gray-400 max-w-2xl mx-auto">Infrastruktur kuat dengan fitur yang dirancang untuk
                        performa tinggi.</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-6 gap-4">
                    <div
                        class="md:col-span-2 glass p-8 rounded-3xl reveal flex flex-col justify-between border-t border-green-500/20">
                        <div>
                            <i class="bi bi-code-slash text-3xl text-green-500 mb-6 block"></i>
                            <h4 class="text-xl font-bold mb-2">REST API Lengkap</h4>
                            <p class="text-gray-500 text-sm">Integrasi mudah ke sistem Anda dengan dokumentasi API yang
                                sangat jelas.</p>
                        </div>
                    </div>
                    <div class="md:col-span-2 glass p-8 rounded-3xl reveal flex flex-col justify-between border-t border-green-500/20"
                        style="transition-delay: 100ms;">
                        <div>
                            <i class="bi bi-lightning-charge-fill text-3xl text-green-500 mb-6 block"></i>
                            <h4 class="text-xl font-bold mb-2">Pengiriman Cepat</h4>
                            <p class="text-gray-500 text-sm">Pesan terkirim dalam hitungan milidetik dengan server
                                latensi rendah.</p>
                        </div>
                    </div>
                    <div class="md:col-span-2 glass p-8 rounded-3xl reveal flex flex-col justify-between border-t border-green-500/20"
                        style="transition-delay: 200ms;">
                        <div>
                            <i class="bi bi-shield-lock-fill text-3xl text-green-500 mb-6 block"></i>
                            <h4 class="text-xl font-bold mb-2">Koneksi Stabil</h4>
                            <p class="text-gray-500 text-sm">Uptime 99.9% menjamin bot Anda selalu siap merespon
                                pelanggan.</p>
                        </div>
                    </div>
                    <!-- More features... -->
                </div>
            </div>
        </section>


        <%- include('partials/footer') %>