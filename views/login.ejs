<%- include('partials/head') %>
    <%- include('partials/nav') %>

        <div class="min-h-screen pt-24 md:pt-32 pb-16 md:pb-20 px-4 md:px-6 flex items-center justify-center hero-gradient">
            <div class="max-w-md w-full glass p-6 md:p-10 rounded-3xl md:rounded-[40px] border border-white/10 popup-float" id="login-card">
                <div class="text-center mb-8 md:mb-10">
                    <div
                        class="w-12 h-12 md:w-16 md:h-16 bg-green-500 rounded-xl md:rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg shadow-green-500/20">
                        <i class="bi bi-person-lock text-black text-2xl md:text-3xl"></i>
                    </div>
                    <h2 class="text-2xl md:text-3xl font-extrabold">Selamat <span class="text-green-500">Datang</span></h2>
                    <p class="text-xs md:text-sm text-gray-400 mt-2">Masuk ke dashboard CloudBot Anda</p>
                </div>

                <form id="login-form" action="/login" method="POST" class="space-y-4 md:space-y-6">
                    <div>
                        <label class="block text-xs font-bold text-gray-400 mb-2 ml-1">Email</label>
                        <div class="relative">
                            <i class="bi bi-envelope absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 text-xs md:text-sm"></i>
                            <input type="email" name="email" required
                                class="auth-input w-full py-3.5 md:py-4 pl-11 md:pl-12 pr-4 rounded-xl md:rounded-2xl text-sm" placeholder="nama@email.com">
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-400 mb-2 ml-1">Password</label>
                        <div class="relative">
                            <i class="bi bi-shield-lock absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 text-xs md:text-sm"></i>
                            <input type="password" name="password" required
                                class="auth-input w-full py-3.5 md:py-4 pl-11 md:pl-12 pr-4 rounded-xl md:rounded-2xl text-sm" placeholder="••••••••">
                        </div>
                    </div>
                    <button type="submit"
                        class="w-full bg-green-500 text-black py-3.5 md:py-4 rounded-xl md:rounded-2xl font-bold hover:bg-green-400 transition-all shadow-lg shadow-green-500/10 text-sm md:text-base">
                        Sign In
                    </button>
                </form>

                <div class="my-6 flex items-center gap-3">
                    <div class="flex-1 h-px bg-white/10"></div>
                    <span class="text-xs text-gray-500 font-semibold uppercase tracking-widest">atau</span>
                    <div class="flex-1 h-px bg-white/10"></div>
                </div>
                <!-- auth google -->
                <a href="/auth/google"
                    class="flex items-center justify-center gap-3 w-full py-3.5 md:py-4 rounded-xl md:rounded-2xl border border-white/10 glass hover:border-white/20 hover:bg-white/5 transition-all font-bold text-sm md:text-base">
                    <svg class="w-5 h-5" viewBox="0 0 24 24">
                        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                    </svg>
                    Masuk dengan Google
                </a>

                <div class="mt-6 text-center text-xs md:text-sm">
                    <p class="text-gray-500">Belum punya akun? <a href="/signup"
                            class="text-green-500 font-bold hover:underline">Daftar Sekarang</a></p>
                </div>
            </div>
        </div>

        <div id="preloader">
            <div class="loader-content popup-float">
                <div class="w-24 h-24 md:w-32 md:h-32 mx-auto mb-6 relative bot-image-container">
                    <img src="/img/bot.png" alt="Bot Mascot" class="w-full h-full drop-shadow-[0_0_20px_rgba(34,197,94,0.4)] bot-img">
                    <div class="water-container"></div>
                </div>
                <h1 class="text-2xl md:text-3xl font-black tracking-[0.2em] mb-1 text-white uppercase">SAIRIBOT</h1>
                <p class="text-gray-500 text-[10px] md:text-xs font-medium mb-8">A fast & smart experience</p>
                <div class="progress-container">
                    <div id="progress-bar"></div>
                </div>
                <div class="flex justify-between mt-2 text-[10px]">
                    <span class="font-bold text-gray-600 uppercase tracking-tighter">Progress</span>
                    <span id="progress-percent" class="font-black text-white italic">0%</span>
                </div>
            </div>
        </div>

        <% if (typeof error !=='undefined' && error) { %>
            <script>
                window.addEventListener('load', () => {
                    showToast('<%= error %>', 'error');
                    shakeElement('login-card');
                });
            </script>
            <% } %>

                <% if (typeof success !=='undefined' && success) { %>
                    <script>
                        window.addEventListener('load', () => {
                            showToast('<%= success %>', 'success');
                        });
                    </script>
                    <% } %>

                        

                        <%- include('partials/footer') %>