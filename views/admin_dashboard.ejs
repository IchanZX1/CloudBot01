<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Super Admin Panel - ZXcoderID</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background-color: #050505;
            color: white;
            overflow-x: hidden;
        }

        /* Glassmorphism */
        .glass-panel {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
        }

        /* Particles Background */
        #particles-js {
            position: fixed;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            z-index: -1;
            background: linear-gradient(135deg, #09090b 0%, #111827 100%);
        }

        /* Pulse Animations for status */
        .status-pulse-green {
            animation: pulse-green 2s infinite;
        }
        @keyframes pulse-green {
            0% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7); }
            70% { box-shadow: 0 0 0 10px rgba(34, 197, 94, 0); }
            100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
        }

        .status-pulse-red {
            animation: pulse-red 2s infinite;
        }
        @keyframes pulse-red {
            0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); }
            70% { box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
            100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
        }

        .status-pulse-yellow {
            animation: pulse-yellow 2s infinite;
        }
        @keyframes pulse-yellow {
            0% { box-shadow: 0 0 0 0 rgba(234, 179, 8, 0.7); }
            70% { box-shadow: 0 0 0 10px rgba(234, 179, 8, 0); }
            100% { box-shadow: 0 0 0 0 rgba(234, 179, 8, 0); }
        }

        /* Custom Scrollbar for Logs */
        .custom-scrollbar::-webkit-scrollbar {
            width: 8px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.02);
            border-radius: 10px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.2);
        }
    </style>
</head>
<body class="antialiased selection:bg-indigo-500/30">

    <!-- Particles Background Container -->
    <div id="particles-js"></div>

    <!-- Glowing Top Accent -->
    <div class="fixed top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-indigo-500 to-transparent shadow-[0_0_15px_rgba(99,102,241,0.5)] z-50"></div>

    <div class="relative z-10 min-h-screen flex flex-col">
        
        <!-- Premium Admin Navbar -->
        <nav class="glass-panel sticky top-0 z-40 border-b border-white/5 py-4 px-6 md:px-10">
            <div class="relative flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-indigo-500 to-purple-500 flex items-center justify-center shadow-lg shadow-indigo-500/20">
                        <i class="bi bi-shield-lock-fill text-xl text-white"></i>
                    </div>
                    <div>
                        <h1 class="font-black text-xl tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-white to-gray-400">ADMINISTRATOR</h1>
                        <p class="text-[10px] text-indigo-400 font-bold uppercase tracking-widest" id="realtime-clock">Memuat Waktu...</p>
                    </div>
                </div>

                <div class="flex items-center gap-4">
                    <a href="/" class="text-sm font-bold text-gray-400 hover:text-white transition-colors"><i class="bi bi-house-door mr-1"></i> Home</a>
                    <a href="/logout" class="px-4 py-2 rounded-lg bg-red-500/20 text-red-500 font-bold text-sm hover:bg-red-500 hover:text-white transition-all border border-red-500/30">Logout <i class="bi bi-box-arrow-right ml-1"></i></a>
                </div>
            </div>
        </nav>

        <main class="flex-grow p-4 md:p-8 lg:p-12 space-y-8">

            <!-- Control & Status Center -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- System Status -->
                <div class="glass-panel p-6 rounded-3xl relative overflow-hidden group">
                    <div class="absolute -right-10 -top-10 w-40 h-40 bg-indigo-500/10 blur-3xl rounded-full group-hover:bg-indigo-500/20 transition-all duration-500"></div>
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-lg font-bold text-gray-200"><i class="bi bi-server mr-2 text-indigo-400"></i> Server Status</h2>
                        <span class="px-3 py-1 bg-green-500/20 text-green-400 text-xs font-bold rounded-full border border-green-500/30 flex items-center gap-2">
                            <span class="w-2 h-2 rounded-full bg-green-500 status-pulse-green"></span> ONLINE
                        </span>
                    </div>
                    <div class="space-y-4">
                        <div>
                            <p class="text-xs text-gray-500 uppercase tracking-widest font-bold mb-1">System Uptime</p>
                            <p class="text-3xl font-black text-white" id="realtime-uptime"><%= uptime %></p>
                        </div>
                        <button onclick="restartServer()" class="w-full py-3 mt-2 rounded-xl bg-indigo-500/20 text-indigo-400 hover:bg-indigo-500 hover:text-white font-bold transition-all border border-indigo-500/30 flex items-center justify-center gap-2">
                            <i class="bi bi-arrow-clockwise"></i> Restart Server
                        </button>
                    </div>
                </div>

                <!-- Error Logs Viewer -->
                <div class="glass-panel p-6 rounded-3xl lg:col-span-2 flex flex-col h-full border-t-[3px] border-t-red-500/50">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-lg font-bold text-gray-200"><i class="bi bi-bug mr-2 text-red-400"></i> Runtime Error Logs</h2>
                        <span class="text-xs text-gray-500 font-mono">log_reportError.txt</span>
                    </div>
                    <div class="bg-[#0a0a0a] rounded-xl p-4 flex-grow border border-white/5 overflow-y-auto custom-scrollbar" style="max-height: 200px;">
                        <pre class="text-xs font-mono text-gray-400 whitespace-pre-wrap"><%= logContent %></pre>
                    </div>
                </div>
            </div>

            <div class="w-full h-[1px] bg-gradient-to-r from-transparent via-white/10 to-transparent my-10"></div>

            <!-- Wings Allocation Management -->
            <div class="glass-panel rounded-3xl p-6 relative overflow-hidden border-t-[3px] border-t-emerald-500/50">
                <div class="absolute -right-16 -bottom-16 w-56 h-56 bg-emerald-500/10 blur-3xl rounded-full"></div>
                <div class="relative flex flex-col lg:flex-row lg:items-start justify-between gap-6">
                    <div class="max-w-2xl">
                        <h2 class="text-2xl font-black"><i class="bi bi-diagram-3-fill mr-2 text-emerald-400"></i> Wings Allocations</h2>
                        <p class="text-sm text-gray-400 mt-1">Buat allocation lalu jalankan command wings yang digenerate. Bot baru akan otomatis diarahkan ke allocation online paling ringan.</p>
                    </div>
                    <button onclick="createAllocation()" class="px-5 py-3 rounded-xl bg-emerald-500/20 text-emerald-300 hover:bg-emerald-500 hover:text-white font-bold transition-all border border-emerald-500/30 flex items-center justify-center gap-2">
                        <i class="bi bi-plus-circle"></i> Create Allocation
                    </button>
                </div>

                <div class="relative grid grid-cols-1 lg:grid-cols-3 gap-4 mt-6">
                    <% const allocationList = typeof allocations !== 'undefined' ? allocations : []; %>
                    <% if (!allocationList.length) { %>
                        <div class="lg:col-span-3 rounded-2xl border border-dashed border-white/10 bg-white/[0.02] p-6 text-center text-sm text-gray-400">
                            Belum ada allocation. Buat allocation pertama untuk menjalankan bot di proses wings terpisah.
                        </div>
                    <% } %>
                    <% allocationList.forEach(allocation => { 
                        const botCount = allocation.bots ? Object.keys(allocation.bots).length : 0;
                    %>
                    <div class="rounded-2xl bg-black/30 border border-white/10 p-5 flex flex-col gap-4">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <h3 class="font-black text-white"><%= allocation.name %></h3>
                                <p class="text-[11px] text-gray-500 font-mono break-all"><%= allocation.uuid %></p>
                            </div>
                            <span class="px-3 py-1 rounded-full text-[10px] font-black border <%= allocation.online ? 'bg-green-500/15 text-green-400 border-green-500/25' : 'bg-red-500/15 text-red-400 border-red-500/25' %>">
                                <%= allocation.online ? 'ONLINE' : 'OFFLINE' %>
                            </span>
                        </div>
                        <div class="grid grid-cols-2 gap-3">
                            <div class="rounded-xl bg-white/5 p-3">
                                <p class="text-[10px] text-gray-500 uppercase font-bold">Port</p>
                                <p class="text-sm font-mono text-gray-200"><%= allocation.port %></p>
                            </div>
                            <div class="rounded-xl bg-white/5 p-3">
                                <p class="text-[10px] text-gray-500 uppercase font-bold">Bots</p>
                                <p class="text-sm font-mono text-gray-200"><%= botCount %>/<%= allocation.maxBots %></p>
                            </div>
                            <div class="col-span-2 rounded-xl bg-white/5 p-3">
                                <p class="text-[10px] text-gray-500 uppercase font-bold">URL</p>
                                <p class="text-xs font-mono text-gray-300 break-all"><%= allocation.url || 'Belum register' %></p>
                            </div>
                        </div>
                        <div class="flex items-center justify-between gap-2 text-xs text-gray-500">
                            <span>Last seen: <%= allocation.lastSeen ? moment(allocation.lastSeen).tz('Asia/Jakarta').format('DD/MM HH:mm:ss') : '-' %></span>
                            <div class="flex items-center gap-2">
                                <button onclick="editAllocation('<%= allocation.uuid %>', '<%= allocation.name %>', '<%= allocation.port %>', '<%= allocation.maxBots %>')" class="px-3 py-2 rounded-lg bg-indigo-500/10 text-indigo-300 hover:bg-indigo-500 hover:text-white font-bold transition-all" title="Edit Allocation">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                                <button onclick="deleteAllocation('<%= allocation.uuid %>')" class="px-3 py-2 rounded-lg bg-red-500/10 text-red-400 hover:bg-red-500 hover:text-white font-bold transition-all" title="Delete Allocation">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>

            <div class="w-full h-[1px] bg-gradient-to-r from-transparent via-white/10 to-transparent my-10"></div>

            <!-- Server User / Bot Management List -->
            <div>
                <% 
                    const pageInfo = typeof pagination !== 'undefined' ? pagination : { page: 1, limit: 24, totalPages: 1, filteredUsers: users.length, totalUsers: users.length, search: '', status: 'all' };
                    const buildAdminPageUrl = (page, extra = {}) => {
                        const params = new URLSearchParams({
                            page: String(page),
                            limit: String(extra.limit || pageInfo.limit),
                            status: extra.status || pageInfo.status || 'all'
                        });
                        const searchValue = extra.search !== undefined ? extra.search : pageInfo.search;
                        if (searchValue) params.set('search', searchValue);
                        return '/admin/dashboard?' + params.toString();
                    };
                    const pageWindowStart = Math.max(1, pageInfo.page - 2);
                    const pageWindowEnd = Math.min(pageInfo.totalPages, pageInfo.page + 2);
                %>
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6 px-2">
                    <div>
                        <h2 class="text-2xl font-black"><i class="bi bi-people-fill mr-2 text-indigo-500"></i> Server Users Management</h2>
                        <p class="text-sm text-gray-400 font-bold"><%= pageInfo.filteredUsers %> ditampilkan dari <%= pageInfo.totalUsers %> Total DB Accounts</p>
                    </div>

                    <form method="GET" action="/admin/dashboard" class="flex flex-col sm:flex-row items-center gap-3 w-full md:w-auto">
                        <input type="hidden" name="page" value="1">
                        <div class="relative w-full sm:w-64">
                            <i class="bi bi-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                            <input type="text" name="search" value="<%= pageInfo.search %>" placeholder="Search username, email, bot..." 
                                class="w-full bg-white/5 border border-white/10 rounded-xl py-2 pl-10 pr-4 text-sm text-white focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-all">
                        </div>
                        <select name="status" class="bg-white/5 border border-white/10 rounded-xl py-2 px-3 text-sm text-white focus:outline-none focus:border-indigo-500">
                            <option value="all" <%= pageInfo.status === 'all' ? 'selected' : '' %>>All</option>
                            <option value="active" <%= pageInfo.status === 'active' ? 'selected' : '' %>>Aktif</option>
                            <option value="inactive" <%= pageInfo.status === 'inactive' ? 'selected' : '' %>>Mati</option>
                        </select>
                        <select name="limit" class="bg-white/5 border border-white/10 rounded-xl py-2 px-3 text-sm text-white focus:outline-none focus:border-indigo-500">
                            <% [12, 24, 48, 96].forEach(size => { %>
                                <option value="<%= size %>" <%= pageInfo.limit === size ? 'selected' : '' %>><%= size %>/page</option>
                            <% }) %>
                        </select>
                        <button type="submit" class="px-4 py-2 rounded-xl bg-indigo-500 text-white font-bold text-sm hover:bg-indigo-600 transition-all">
                            Filter
                        </button>
                    </form>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 relative" id="usersGrid">
                    <% if (!users.length) { %>
                        <div class="md:col-span-2 xl:col-span-3 rounded-2xl border border-dashed border-white/10 bg-white/[0.02] p-8 text-center text-sm text-gray-400">
                            Tidak ada user yang cocok dengan filter saat ini.
                        </div>
                    <% } %>
                    <% users.forEach(u => { 
                        const botNum = (u.no_Bot || u.no_Wa || '').replace(/[^0-9]/g, '');
                        // get actual stat
                        const stateStr = botStatus.states[botNum] || 'offline';
                        let indicatorClass = 'bg-red-500 status-pulse-red';
                        let stateText = 'Offline (Stopped)';
                        
                        if(stateStr === 'open') {
                            indicatorClass = 'bg-green-500 status-pulse-green';
                            stateText = 'Running Active';
                        } else if (stateStr === 'connecting') {
                            indicatorClass = 'bg-yellow-500 status-pulse-yellow';
                            stateText = 'Reconnecting...';
                        }
                    %>
                    <div class="user-card glass-panel rounded-3xl p-6 relative flex flex-col group overflow-hidden hover:border-indigo-500/30 transition-all duration-300" data-status="<%= stateStr === 'open' ? 'active' : 'inactive' %>">
                        <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-indigo-500 to-purple-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        
                        <!-- Header / Status Indicator -->
                        <div class="flex justify-between items-start mb-4">
                            <div class="flex items-center gap-3">
                                <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-white/10 shrink-0">
                                    <img src="<%= u.profilePic || '/img/default-profile.png' %>" class="w-full h-full object-cover">
                                </div>
                                <div>
                                    <h3 class="font-bold text-white text-lg leading-tight truncate w-[140px]"><%= u.username %></h3>
                                    <p class="text-xs text-gray-400 font-mono"><%= u.email %></p>
                                </div>
                            </div>
                            
                            <!-- Dot pulse status -->
                            <div class="flex items-center gap-2 bg-black/40 px-3 py-1.5 rounded-full border border-white/5" title="<%= stateText %>">
                                <div class="w-2.5 h-2.5 rounded-full <%= indicatorClass %>"></div>
                                <span class="text-[10px] font-bold text-gray-300 uppercase"><%= stateStr %></span>
                            </div>
                        </div>

                        <!-- Data & Package -->
                        <div class="grid grid-cols-2 gap-3 mb-6 bg-white/5 rounded-2xl p-4 border border-white/5">
                            <div>
                                <p class="text-[10px] text-gray-500 uppercase tracking-widest font-bold">Package Plan</p>
                                <p class="text-sm font-black text-indigo-400"><%= u.paket %></p>
                            </div>
                            <div>
                                <p class="text-[10px] text-gray-500 uppercase tracking-widest font-bold">Role Access</p>
                                <p class="text-sm font-bold <%= u.role === 'admin' ? 'text-purple-400' : 'text-gray-200' %>"><%= u.role %></p>
                            </div>
                            <div class="col-span-2">
                                <p class="text-[10px] text-gray-500 uppercase tracking-widest font-bold">Target Bot Number</p>
                                <p class="text-sm font-mono text-gray-300"><%= u.no_Bot || 'Belum Set' %></p>
                            </div>
                        </div>

                        <!-- Action Buttons at Bottom -->
                        <div class="mt-auto flex justify-between items-center gap-1 border-t border-white/10 pt-4">
                            <button onclick="editUser('<%= u._id %>', '<%= u.username %>', '<%= u.email %>', '<%= u.no_Wa %>', '<%= u.paket %>')" 
                                class="flex-1 py-1.5 rounded-xl bg-white/5 hover:bg-white/10 text-gray-300 font-bold text-xs transition-colors flex items-center justify-center gap-1" title="Edit Data">
                                <i class="bi bi-pencil-square"></i> Edit
                            </button>
                            <button onclick="adminBotAction('<%= botNum %>', 'start')" class="flex-none w-[36px] h-[36px] rounded-xl bg-green-500/10 hover:bg-green-500 text-green-500 hover:text-white transition-all border border-green-500/20 flex items-center justify-center" title="Start Bot">
                                <i class="bi bi-play-fill text-lg"></i>
                            </button>
                            <button onclick="adminBotAction('<%= botNum %>', 'stop')" class="flex-none w-[36px] h-[36px] rounded-xl bg-yellow-500/10 hover:bg-yellow-500 text-yellow-500 hover:text-white transition-all border border-yellow-500/20 flex items-center justify-center" title="Stop Bot">
                                <i class="bi bi-stop-fill text-lg"></i>
                            </button>
                            <button onclick="deleteAccount('<%= u._id %>', '<%= u.email %>')" class="flex-none w-[36px] h-[36px] rounded-xl bg-red-500/10 hover:bg-red-500 text-red-500 hover:text-white transition-all border border-red-500/20 flex items-center justify-center" title="Delete Account">
                                <i class="bi bi-trash3-fill text-lg"></i>
                            </button>
                            <% if (stateStr === 'open') { %>
                            <a href="/api/admin/bot/session/<%= botNum %>" class="flex-none w-[36px] h-[36px] rounded-xl bg-indigo-500/10 hover:bg-indigo-500 text-indigo-400 hover:text-white transition-all border border-indigo-500/20 flex items-center justify-center" title="Download creds.json">
                                <i class="bi bi-cloud-arrow-down-fill text-lg"></i>
                            </a>
                            <% } %>
                        </div>
                    </div>
                    <% }) %>
                </div>

                <div class="mt-8 flex flex-col md:flex-row items-center justify-between gap-4 rounded-2xl bg-white/[0.03] border border-white/10 p-4">
                    <p class="text-xs text-gray-400 font-bold">
                        Page <span class="text-white"><%= pageInfo.page %></span> of <span class="text-white"><%= pageInfo.totalPages %></span>
                    </p>
                    <div class="flex items-center gap-2 flex-wrap justify-center">
                        <a href="<%= buildAdminPageUrl(Math.max(pageInfo.page - 1, 1)) %>" class="px-3 py-2 rounded-lg border border-white/10 text-xs font-bold <%= pageInfo.page <= 1 ? 'pointer-events-none text-gray-600 bg-white/[0.02]' : 'text-gray-300 hover:bg-white/10' %>">
                            Prev
                        </a>
                        <% for (let pageNumber = pageWindowStart; pageNumber <= pageWindowEnd; pageNumber++) { %>
                            <a href="<%= buildAdminPageUrl(pageNumber) %>" class="px-3 py-2 rounded-lg border text-xs font-bold <%= pageNumber === pageInfo.page ? 'bg-indigo-500 border-indigo-500 text-white' : 'border-white/10 text-gray-300 hover:bg-white/10' %>">
                                <%= pageNumber %>
                            </a>
                        <% } %>
                        <a href="<%= buildAdminPageUrl(Math.min(pageInfo.page + 1, pageInfo.totalPages)) %>" class="px-3 py-2 rounded-lg border border-white/10 text-xs font-bold <%= pageInfo.page >= pageInfo.totalPages ? 'pointer-events-none text-gray-600 bg-white/[0.02]' : 'text-gray-300 hover:bg-white/10' %>">
                            Next
                        </a>
                    </div>
                </div>
            </div>

        </main>
    </div>

    <!-- Scripts -->
    <script>
        // Realtime Clock Asia/Jakarta
        function updateClock() {
            const now = new Date();
            const options = { timeZone: 'Asia/Jakarta', weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false };
            const formatter = new Intl.DateTimeFormat('id-ID', options);
            document.getElementById('realtime-clock').innerText = formatter.format(now) + ' WIB';
        }
        setInterval(updateClock, 1000);
        updateClock();

        // Server Uptime Realtime Updater
        let currentUptime = <%= typeof uptimeSeconds !== 'undefined' ? uptimeSeconds : 0 %>;
        function updateUptime() {
            currentUptime++;
            let h = Math.floor(currentUptime / 3600);
            let m = Math.floor((currentUptime % 3600) / 60);
            let s = currentUptime % 60;
            document.getElementById('realtime-uptime').innerText = `${h}h ${m}m ${s}s`;
        }
        setInterval(updateUptime, 1000);

        // Server Restart
        async function restartServer() {
            const confirmed = await Swal.fire({
                title: 'Restart Server?',
                text: "Proses Node.js akan dihentikan dan restart otomatis melalui process manager (PM2/Nodemon). Bot yang berjalan akan reconnecting.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#6366f1',
                cancelButtonColor: '#333',
                confirmButtonText: 'Ya, Restart Sekarang',
                background: '#121212',
                color: '#fff'
            });

            if(confirmed.isConfirmed) {
                try {
                    const res = await fetch('/api/admin/server/restart', { method: 'POST' });
                    if(res.ok) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Restarting...',
                            text: 'Harap tunggu beberapa detik lalu refresh halaman',
                            showConfirmButton: false,
                            background: '#121212',
                            color: '#fff',
                            timer: 5000
                        }).then(() => location.reload());
                    }
                } catch(err) {}
            }
        }

        async function createAllocation() {
            const { value: formValues } = await Swal.fire({
                title: 'Create Wings Allocation',
                html: `
                    <div class="text-left space-y-3 mt-4">
                        <div>
                            <label class="text-xs font-bold text-gray-400">Nama Allocation</label>
                            <input id="allocation-name" class="swal2-input !m-0 !w-full" placeholder="allocation01">
                        </div>
                        <div>
                            <label class="text-xs font-bold text-gray-400">Port Wings</label>
                            <input id="allocation-port" type="number" class="swal2-input !m-0 !w-full" placeholder="3101">
                        </div>
                        <div>
                            <label class="text-xs font-bold text-gray-400">Max Bot di Allocation Ini</label>
                            <input id="allocation-max" type="number" class="swal2-input !m-0 !w-full" value="5">
                        </div>
                    </div>
                `,
                focusConfirm: false,
                showCancelButton: true,
                confirmButtonColor: '#22c55e',
                background: '#121212',
                color: '#fff',
                preConfirm: () => ({
                    name: document.getElementById('allocation-name').value,
                    port: document.getElementById('allocation-port').value,
                    maxBots: document.getElementById('allocation-max').value
                })
            });

            if (!formValues) return;

            try {
                const res = await fetch('/api/admin/allocations/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formValues)
                });
                const result = await res.json();
                if (!result.success) return Swal.fire('Error', result.error, 'error');

                const command = result.allocation.command;
                await Swal.fire({
                    icon: 'success',
                    title: 'Allocation Dibuat',
                    html: `
                        <p class="text-sm text-gray-300 mb-3">Jalankan command ini di terminal/server wings:</p>
                        <textarea id="wings-command" class="swal2-textarea !w-full !h-28 !m-0 font-mono text-xs" readonly>${command}</textarea>
                    `,
                    showCancelButton: true,
                    confirmButtonText: 'Copy Command',
                    cancelButtonText: 'Tutup',
                    confirmButtonColor: '#22c55e',
                    background: '#121212',
                    color: '#fff',
                    preConfirm: async () => {
                        const textarea = document.getElementById('wings-command');
                        textarea.select();
                        await navigator.clipboard.writeText(textarea.value);
                    }
                });
                location.reload();
            } catch (err) {
                Swal.fire('Error', 'Gagal komunikasi server', 'error');
            }
        }

        async function deleteAllocation(uuid) {
            const confirmed = await Swal.fire({
                title: 'Hapus Allocation?',
                text: 'Bot yang sedang berjalan di wings ini harus dihentikan/manual start ulang di allocation lain.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#333',
                confirmButtonText: 'Hapus',
                background: '#121212',
                color: '#fff'
            });

            if (!confirmed.isConfirmed) return;

            try {
                const res = await fetch('/api/admin/allocations/delete/' + uuid, { method: 'POST' });
                const result = await res.json();
                if (result.success) return location.reload();
                Swal.fire('Error', result.error, 'error');
            } catch (err) {
                Swal.fire('Error', 'Gagal komunikasi server', 'error');
            }
        }

        async function editAllocation(uuid, name, port, maxBots) {
            const { value: formValues } = await Swal.fire({
                title: 'Edit Allocation',
                html: `
                    <div class="text-left space-y-3 mt-4">
                        <div>
                            <label class="text-xs font-bold text-gray-400">Nama Allocation</label>
                            <input id="edit-allocation-name" class="swal2-input !m-0 !w-full" value="${name}">
                        </div>
                        <div>
                            <label class="text-xs font-bold text-gray-400">Port Wings</label>
                            <input id="edit-allocation-port" type="number" class="swal2-input !m-0 !w-full" value="${port}">
                            <p class="text-[11px] text-gray-500 mt-1">Ubah port hanya kalau command wings dan reverse proxy juga ikut diubah.</p>
                        </div>
                        <div>
                            <label class="text-xs font-bold text-gray-400">Max Bot</label>
                            <input id="edit-allocation-max" type="number" min="1" max="1000" class="swal2-input !m-0 !w-full" value="${maxBots}">
                        </div>
                    </div>
                `,
                focusConfirm: false,
                showCancelButton: true,
                confirmButtonColor: '#6366f1',
                background: '#121212',
                color: '#fff',
                preConfirm: () => ({
                    name: document.getElementById('edit-allocation-name').value,
                    port: document.getElementById('edit-allocation-port').value,
                    maxBots: document.getElementById('edit-allocation-max').value
                })
            });

            if (!formValues) return;

            try {
                const res = await fetch('/api/admin/allocations/update/' + uuid, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formValues)
                });
                const result = await res.json();
                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Allocation Updated',
                        text: 'Limit bot allocation berhasil diperbarui.',
                        background: '#121212',
                        color: '#fff'
                    }).then(() => location.reload());
                } else {
                    Swal.fire('Error', result.error, 'error');
                }
            } catch (err) {
                Swal.fire('Error', 'Gagal komunikasi server', 'error');
            }
        }

        // Delete User
        async function deleteAccount(id, email) {
            const confirmed = await Swal.fire({
                title: 'Hapus Akun?',
                text: "Yakin menghapus " + email + "? Semua data di database akan hilang.",
                icon: 'error',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#333',
                confirmButtonText: 'Hapus!',
                background: '#121212',
                color: '#fff'
            });

            if(confirmed.isConfirmed) {
                try {
                    const res = await fetch('/api/admin/users/delete/' + id, { method: 'POST' });
                    const result = await res.json();
                    if(result.success) {
                        location.reload();
                    } else {
                        Swal.fire('Error', result.error, 'error');
                    }
                } catch(err) {
                    Swal.fire('Error', 'Gagal komunikasi server', 'error');
                }
            }
        }

        // Edit User Wrapper (Sweetalert Form)
        async function editUser(id, username, email, no_Wa, paket) {
            const { value: formValues } = await Swal.fire({
                title: 'Edit User Account',
                html: `
                    <div class="text-left space-y-3 mt-4">
                        <div>
                            <label class="text-xs font-bold text-gray-400">Username</label>
                            <input id="swal-username" class="swal2-input !m-0 !w-full" value="${username}">
                        </div>
                        <div>
                            <label class="text-xs font-bold text-gray-400">Email</label>
                            <input id="swal-email" type="email" class="swal2-input !m-0 !w-full" value="${email}">
                        </div>
                        <div>
                            <label class="text-xs font-bold text-gray-400">No WA/Bot</label>
                            <input id="swal-noWa" class="swal2-input !m-0 !w-full" value="${no_Wa}">
                        </div>
                        <div>
                            <label class="text-xs font-bold text-gray-400">Paket (free, trial, Basic, Starter)</label>
                            <input id="swal-paket" class="swal2-input !m-0 !w-full" value="${paket}">
                        </div>
                    </div>
                `,
                focusConfirm: false,
                showCancelButton: true,
                confirmButtonColor: '#6366f1',
                background: '#121212',
                color: '#fff',
                preConfirm: () => {
                    return {
                        username: document.getElementById('swal-username').value,
                        email: document.getElementById('swal-email').value,
                        no_Wa: document.getElementById('swal-noWa').value,
                        paket: document.getElementById('swal-paket').value
                    }
                }
            });

            if (formValues) {
                try {
                    const res = await fetch('/api/admin/users/update/' + id, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(formValues)
                    });
                    const result = await res.json();
                    if(result.success) {
                        location.reload();
                    } else {
                        Swal.fire('Error', result.error, 'error');
                    }
                } catch(e) {
                    Swal.fire('Error', 'Gagal komunikasi server', 'error');
                }
            }
        }

        // Start / Stop Bot Action
        async function adminBotAction(botNum, action) {
            if (!botNum) return Swal.fire('Oops!', 'Sistem tidak menemukan nomor Bot. Coba suruh pengguna Connect terlebih dahulu, atau Anda bisa mengatur nomor tersebut di tombol Edit.', 'info');
            
            const actionText = action === 'start' ? 'Menghidupkan' : 'Mematikan';
            const confirmed = await Swal.fire({
                title: actionText + ' Bot?',
                text: "Memaksa " + actionText.toLowerCase() + " bot dengan nomor " + botNum,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: action === 'start' ? '#22c55e' : '#eab308',
                cancelButtonColor: '#333',
                confirmButtonText: 'Ya, Eksekusi',
                background: '#121212',
                color: '#fff'
            });

            if(confirmed.isConfirmed) {
                try {
                    const res = await fetch('/api/admin/bot/action', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action, botNum })
                    });
                    const result = await res.json();
                    if(result.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Berhasil',
                            text: result.message,
                            background: '#121212',
                            color: '#fff'
                        }).then(() => location.reload());
                    } else {
                        Swal.fire('Error', result.error, 'error');
                    }
                } catch(e) {
                    Swal.fire('Error', 'Gagal komunikasi dengan server', 'error');
                }
            }
        }

    </script>
</body>
</html>
