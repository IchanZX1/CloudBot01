<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="pt-24 pb-12 px-4 md:px-6 min-h-screen">
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="mb-10 reveal">
            <h1 class="text-3xl md:text-5xl font-extrabold mb-2">Riwayat <span class="text-green-500">Invoice</span></h1>
            <p class="text-gray-400">Pantau semua status pembayaran dan riwayat transaksi paket layanan Anda.</p>
        </div>

        <!-- History Table -->
        <div class="glass rounded-[32px] overflow-hidden border border-white/5 reveal">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-white/[0.02] border-b border-white/5">
                            <th class="px-6 py-5 text-xs font-bold uppercase tracking-widest text-gray-500">ID Transaksi</th>
                            <th class="px-6 py-5 text-xs font-bold uppercase tracking-widest text-gray-500">Produk</th>
                            <th class="px-6 py-5 text-xs font-bold uppercase tracking-widest text-gray-500">Nominal</th>
                            <th class="px-6 py-5 text-xs font-bold uppercase tracking-widest text-gray-500">Tanggal</th>
                            <th class="px-6 py-5 text-xs font-bold uppercase tracking-widest text-gray-500 text-center">Status</th>
                            <th class="px-6 py-5 text-xs font-bold uppercase tracking-widest text-gray-500 text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        <% if (deposits && deposits.length > 0) { %>
                            <% deposits.forEach(deposit => { %>
                                <tr class="hover:bg-white/[0.02] transition-all group">
                                    <td class="px-6 py-5">
                                        <span class="font-mono text-sm text-gray-300">#<%= deposit.reffId %></span>
                                    </td>
                                    <td class="px-6 py-5">
                                        <div class="flex flex-col">
                                            <span class="font-bold text-sm text-white"><%= deposit.packageId ? deposit.packageId.name : 'Unknown' %></span>
                                            <span class="text-[10px] text-gray-500">WhatsApp Bot Package</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-5">
                                        <span class="font-bold text-green-500 italic">Rp <%= deposit.nominal.toLocaleString('id-ID') %></span>
                                    </td>
                                    <td class="px-6 py-5 text-sm text-gray-400">
                                        <%= moment(deposit.createdAt).tz('Asia/Jakarta').format('DD MMM YYYY, HH:mm') %>
                                    </td>
                                    <td class="px-6 py-5 text-center">
                                        <% if (deposit.status === 'success') { %>
                                            <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold bg-green-500/10 text-green-500 border border-green-500/20 uppercase tracking-tighter">
                                                <i class="bi bi-patch-check-fill mr-1.5"></i> Paid
                                            </span>
                                        <% } else if (deposit.status === 'pending') { %>
                                            <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold bg-yellow-500/10 text-yellow-500 border border-yellow-500/20 uppercase tracking-tighter">
                                                <i class="bi bi-clock-history mr-1.5"></i> Pending
                                            </span>
                                        <% } else if (deposit.status === 'failed') { %>
                                            <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold bg-red-500/10 text-red-500 border border-red-500/20 uppercase tracking-tighter">
                                                <i class="bi bi-x-circle-fill mr-1.5"></i> Failed
                                            </span>
                                        <% } else if (deposit.status === 'expired') { %>
                                             <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold bg-gray-500/10 text-gray-400 border border-white/5 uppercase tracking-tighter">
                                                 <i class="bi bi-calendar-x mr-1.5"></i> Expired
                                             </span>
                                         <% } else { %>
                                            <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold bg-gray-500/10 text-gray-400 border border-white/5 uppercase tracking-tighter">
                                                <i class="bi bi-dash-circle-fill mr-1.5"></i> Cancelled
                                            </span>
                                        <% } %>
                                    </td>
                                    <td class="px-6 py-5 text-center">
                                        <button 
                                            onclick="showInvoiceDetail(this)" 
                                            data-deposit='<%= JSON.stringify(deposit) %>'
                                            class="w-8 h-8 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:bg-green-500 hover:text-black hover:border-green-500 transition-all active:scale-90"
                                        >
                                            <i class="bi bi-eye-fill"></i>
                                        </button>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="px-6 py-20 text-center">
                                    <div class="flex flex-col items-center opacity-30">
                                        <i class="bi bi-invoices text-5xl mb-4"></i>
                                        <p class="font-bold text-gray-300 uppercase tracking-widest text-xs">Belum ada riwayat transaksi</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<!-- Premium Invoice Modal -->
<div id="invoice-modal" class="fixed inset-0 z-[1000] flex items-center justify-center p-4 md:p-6 opacity-0 pointer-events-none transition-all duration-300">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/80 backdrop-blur-md" onclick="closeInvoiceModal()"></div>
    
    <!-- Modal Content -->
    <div class="relative w-full max-w-md md:max-w-3xl bg-[#0a0a0a] rounded-[48px] border border-white/10 shadow-3xl transform scale-95 transition-all duration-300 max-h-[90vh] flex flex-col" id="modal-box">
        <!-- Floating Glows -->
        <div class="absolute -top-24 -right-24 w-64 h-64 bg-green-500/10 blur-[80px] rounded-full pointer-events-none"></div>
        <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-green-500/5 blur-[80px] rounded-full pointer-events-none"></div>

        <!-- Header (Fixed at top) -->
        <div class="p-6 md:p-8 text-center relative z-10 border-b border-white/5 bg-[#0a0a0a]/80 backdrop-blur-xl rounded-t-[48px]">
            <div class="flex items-center justify-center space-x-3 mb-2">
                <div class="w-10 h-10 bg-green-500 rounded-xl flex items-center justify-center shadow-lg shadow-green-500/20">
                    <i class="bi bi-receipt-cutoff text-lg text-black"></i>
                </div>
                <div>
                    <h2 class="text-xl font-black text-white uppercase tracking-tight">Struk Pembayaran</h2>
                    <p class="text-[10px] text-gray-500 uppercase tracking-[4px] font-bold text-left">ZXcoderID <span class="text-green-500">Cloud</span></p>
                </div>
            </div>
        </div>
        
        <!-- Scrollable Content Body -->
        <div class="flex-grow overflow-y-auto custom-scrollbar p-6 md:p-10 relative z-10">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
                
                <!-- Left: Details -->
                <div class="space-y-6">
                    <div id="modal-status-badge">
                        <!-- Injected via JS -->
                    </div>

                    <div class="space-y-4 text-sm bg-white/[0.02] p-6 rounded-[32px] border border-white/5">
                        <div class="flex justify-between items-center group">
                            <span class="text-gray-500">Customer</span>
                            <span class="font-bold text-white uppercase" id="m-user"><%= user.username %></span>
                        </div>
                        <div class="flex justify-between items-center group">
                            <span class="text-gray-500">ID Transaksi</span>
                            <div class="flex items-center space-x-2">
                                <span class="font-mono text-gray-300" id="m-trx">#ZX...</span>
                                <button onclick="copyTrxId()" class="p-1 hover:text-green-500 transition-colors">
                                    <i class="bi bi-copy text-[10px]"></i>
                                </button>
                            </div>
                        </div>
                        <div class="flex justify-between items-center py-2 border-t border-white/5 mt-2">
                            <span class="text-gray-500">Keterangan Paket</span>
                            <span class="font-bold text-white text-right" id="m-package">Basic Plan</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-500">Dibuat</span>
                            <span class="text-gray-300" id="m-created">12/12/2024</span>
                        </div>
                        <div class="flex justify-between items-center" id="m-paid-row">
                            <span class="text-gray-500 font-bold" id="m-paid-label">Dibayar</span>
                            <span class="text-green-500 font-bold text-right" id="m-paid">-</span>
                        </div>
                    </div>

                    <div class="pt-6 border-t border-dashed border-white/10 flex justify-between items-center px-2">
                        <span class="font-bold text-gray-500 uppercase tracking-widest text-xs">Total</span>
                        <span class="text-3xl font-black text-green-500 italic" id="m-total">Rp 0</span>
                    </div>

                    <!-- Cancel button with Green Stroke/Glow as requested -->
                    <div id="m-cancel-container" class="hidden pt-6">
                        <button onclick="cancelOrderFromInvoice()" class="w-full py-4 rounded-2xl border-2 border-green-500/50 bg-green-500/10 text-green-500 font-black text-xs uppercase tracking-[2px] transition-all hover:bg-green-500 hover:text-black shadow-[0_0_20px_rgba(34,197,94,0.2)] active:scale-95 flex items-center justify-center space-x-2">
                            <i class="bi bi-x-circle-fill"></i>
                            <span>Batalkan Pesanan</span>
                        </button>
                        <p class="text-[9px] text-gray-500 mt-3 text-center italic">* Klik tombol hijau di atas untuk membatalkan transaksi ini.</p>
                    </div>
                </div>

                <!-- Right: QRIS (Only shown when pending) -->
                <div id="m-pending-section" class="hidden">
                    <div class="bg-white/5 rounded-[40px] p-6 md:p-8 border border-white/5 text-center relative overflow-hidden group">
                        <div class="absolute inset-0 bg-green-500/5 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
                        
                        <div class="relative z-10">
                            <p class="text-[10px] font-black text-yellow-500 uppercase tracking-[3px] mb-6">QRIS PAYMENT</p>
                            
                            <div class="bg-white p-4 rounded-3xl inline-block mb-6 shadow-2xl relative">
                                <img id="m-qris-img" src="" alt="QRIS" class="w-40 h-40 md:w-56 md:h-56 object-contain">
                                <!-- Download Button Overlay -->
                                <button onclick="downloadQR()" class="absolute -bottom-3 -right-3 w-10 h-10 bg-green-500 text-black rounded-full flex items-center justify-center shadow-lg hover:scale-110 active:scale-90 transition-all">
                                    <i class="bi bi-download"></i>
                                </button>
                            </div>
                            
                            <div class="space-y-4">
                                <div class="flex items-center justify-center space-x-2 text-red-500 font-bold bg-red-500/10 py-3 px-6 rounded-2xl border border-red-500/20 text-sm animate-pulse">
                                    <i class="bi bi-clock-history"></i>
                                    <span>Expired: <span id="m-countdown" class="font-mono">00:00</span></span>
                                </div>
                                
                                <p class="text-[11px] text-gray-400 leading-relaxed">
                                    Simpan QR Code atau scan langsung untuk bayar.<br>
                                    <span class="text-white font-bold italic">Otomatis terkonfirmasi dalam 1-5 menit.</span>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer Message -->
            <div class="mt-12 text-center border-t border-white/5 pt-8">
                <p class="text-[10px] text-gray-600 font-bold italic mb-6 uppercase tracking-widest">Terima kasih telah berlangganan ZXcoderID Cloud</p>
                <div class="max-w-xs mx-auto">
                    <button onclick="closeInvoiceModal()" class="w-full py-4 bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl text-xs font-black transition-all uppercase tracking-widest text-gray-400 hover:text-white">Close Details</button>
                </div>
            </div>
        </div>

        <!-- Notches -->
        <div class="absolute top-1/2 -left-4 w-8 h-8 bg-[#050505] rounded-full transform -translate-y-1/2 border border-white/10 hidden md:block"></div>
        <div class="absolute top-1/2 -right-4 w-8 h-8 bg-[#050505] rounded-full transform -translate-y-1/2 border border-white/10 hidden md:block"></div>
    </div>
</div>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(34, 197, 94, 0.2);
        border-radius: 20px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: rgba(34, 197, 94, 0.5);
    }
    #modal-box {
        overflow: hidden;
    }
    .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .reveal.active {
        opacity: 1;
        transform: translateY(0);
    }
    .glass {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }
</style>

<%- include('partials/footer') %>
