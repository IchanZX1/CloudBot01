<%- include('partials/head') %>
    <%- include('partials/nav') %>

        <style>
            .feature-toggle input:checked + .feature-card {
                border-color: rgba(34, 197, 94, 0.55);
                background: rgba(34, 197, 94, 0.10);
            }

            .feature-toggle input:checked + .feature-card .feature-icon,
            .feature-toggle input:checked + .feature-card .feature-label {
                color: #22c55e;
            }

            .feature-toggle input:checked + .feature-card .feature-switch {
                background: rgba(34, 197, 94, 0.20);
                border-color: rgba(34, 197, 94, 0.35);
            }

            .feature-toggle input:checked + .feature-card .feature-knob {
                transform: translateX(16px);
                background: #22c55e;
            }

            /* Welcome design radio card styles */
            .welcome-design-option input:checked + div {
                border-color: rgba(34, 197, 94, 0.75);
                background: rgba(34, 197, 94, 0.08);
            }
            .welcome-design-option input:checked + div img {
                opacity: 1;
            }
            .welcome-design-option input:checked + div .radio-dot {
                border-color: #22c55e;
            }
            .welcome-design-option input:checked + div .radio-dot span {
                display: block;
            }
            .welcome-design-option input:checked + div .label-text {
                color: #22c55e;
            }

            .duration-option input:checked + .duration-card {
                border-color: rgba(234, 179, 8, 0.7);
                background: rgba(234, 179, 8, 0.12);
                color: #eab308;
            }
        </style>

        <div class="min-h-screen pt-24 md:pt-32 pb-16 md:pb-20 px-4 md:px-6 hero-gradient">
            <div class="container-responsive text-center mb-8 md:mb-12 popup-float">
                <h2 class="text-2xl md:text-4xl font-extrabold mb-2 text-white">Group Settings</h2>
                <p class="text-xs md:text-sm text-gray-400">Kelola pengaturan grup dari session bot WhatsApp yang sedang tersambung.</p>
                <div class="mt-4 flex justify-center">
                    <span id="group-bot-status" class="px-4 py-1.5 rounded-full bg-yellow-500/10 border border-yellow-500/20 text-xs font-bold text-yellow-500 flex items-center gap-2">
                        <i class="bi bi-hourglass-split"></i>
                        Loading session bot
                    </span>
                </div>
            </div>

            <div class="container-responsive grid grid-cols-1 lg:grid-cols-12 gap-6 md:gap-8 items-start">
                <section class="lg:col-span-4 glass p-5 md:p-8 rounded-2xl md:rounded-[32px] border border-white/10 popup-float">
                    <div class="flex items-center gap-3 mb-6 pb-5 border-b border-white/5">
                        <div class="w-11 h-11 bg-green-500/20 rounded-2xl flex items-center justify-center text-green-500 text-xl shrink-0">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <div>
                            <h4 class="text-lg font-extrabold text-white">Pilih Group</h4>
                            <p class="text-xs text-gray-500">Data diambil dari bot yang aktif.</p>
                        </div>
                    </div>

                    <label for="group-select" class="block text-[10px] font-black text-gray-500 uppercase tracking-widest mb-3">Group WhatsApp</label>
                    <div class="relative">
                        <select id="group-select" class="auth-input w-full py-3 px-4 pr-10 rounded-xl text-sm appearance-none cursor-pointer">
                            <option value="">Memuat daftar group...</option>
                        </select>
                        <i class="bi bi-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 text-xs pointer-events-none"></i>
                    </div>

                    <div id="selected-group-info" class="mt-5 bg-white/5 rounded-2xl p-4 border border-white/5 hidden">
                        <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-2">Detail Group</p>
                        <h5 id="group-name" class="text-white font-extrabold text-sm break-words"></h5>
                        <p id="group-id" class="text-[11px] text-gray-500 font-mono mt-2 break-all"></p>
                        <p id="group-desc" class="text-xs text-gray-400 mt-3 leading-relaxed"></p>
                        <div id="group-rental-status" class="mt-4 rounded-xl bg-black/20 border border-white/5 px-3 py-2 text-xs text-gray-400">
                            Group tidak disewakan
                        </div>
                    </div>

                    <div class="mt-5 rounded-2xl border border-white/10 bg-white/5 overflow-hidden">
                        <button type="button" id="rental-toggle" class="w-full px-4 py-4 flex items-center justify-between text-left hover:bg-white/5 transition-all">
                            <span class="flex items-center gap-3">
                                <span class="w-9 h-9 rounded-xl bg-yellow-500/15 text-yellow-500 flex items-center justify-center">
                                    <i class="bi bi-calendar2-week"></i>
                                </span>
                                <span>
                                    <span class="block text-sm font-extrabold text-white">Sewa Group</span>
                                    <span class="block text-[10px] text-gray-500">Atur masa aktif bot di group</span>
                                </span>
                            </span>
                            <i id="rental-toggle-icon" class="bi bi-chevron-down text-gray-500 transition-transform"></i>
                        </button>
                        <div id="rental-panel" class="hidden px-4 pb-4 border-t border-white/5">
                            <form id="group-rental-form" class="space-y-4 pt-4">
                                <div>
                                    <label class="block text-[10px] font-black text-gray-500 uppercase tracking-widest mb-2">URL Group</label>
                                    <input type="url" name="group_url" class="auth-input w-full py-3 px-4 rounded-xl text-sm"
                                        placeholder="https://chat.whatsapp.com/xxxx">
                                    <p id="rental-preview" class="text-[11px] text-gray-500 mt-2">Masukkan URL invite untuk mengambil nama group.</p>
                                </div>
                                <input type="hidden" name="group_name">
                                <div>
                                    <label class="block text-[10px] font-black text-gray-500 uppercase tracking-widest mb-2">Durasi</label>
                                    <div class="grid grid-cols-2 gap-2">
                                        <label class="duration-option cursor-pointer">
                                            <input type="radio" name="duration_type" value="7" class="sr-only" checked>
                                            <span class="duration-card block text-center rounded-xl border border-white/10 bg-white/5 px-3 py-3 text-xs font-bold text-gray-400">7 Hari</span>
                                        </label>
                                        <label class="duration-option cursor-pointer">
                                            <input type="radio" name="duration_type" value="15" class="sr-only">
                                            <span class="duration-card block text-center rounded-xl border border-white/10 bg-white/5 px-3 py-3 text-xs font-bold text-gray-400">15 Hari</span>
                                        </label>
                                        <label class="duration-option cursor-pointer">
                                            <input type="radio" name="duration_type" value="30" class="sr-only">
                                            <span class="duration-card block text-center rounded-xl border border-white/10 bg-white/5 px-3 py-3 text-xs font-bold text-gray-400">30 Hari</span>
                                        </label>
                                        <label class="duration-option cursor-pointer">
                                            <input type="radio" name="duration_type" value="custom" class="sr-only">
                                            <span class="duration-card flex items-center justify-center gap-2 rounded-xl border border-white/10 bg-white/5 px-3 py-3 text-xs font-bold text-gray-400">
                                                <i class="bi bi-calendar-event"></i>
                                                Custom
                                            </span>
                                        </label>
                                    </div>
                                </div>
                                <div id="custom-date-wrap" class="hidden">
                                    <label class="block text-[10px] font-black text-gray-500 uppercase tracking-widest mb-2">Tanggal Berakhir</label>
                                    <div class="relative">
                                        <i class="bi bi-calendar-event absolute left-4 top-1/2 -translate-y-1/2 text-gray-500"></i>
                                        <input type="date" name="custom_date" class="auth-input w-full py-3 pl-11 pr-4 rounded-xl text-sm">
                                    </div>
                                </div>
                                <button type="submit" id="save-rental-btn" class="w-full py-3.5 rounded-xl bg-yellow-500 text-black text-xs font-black uppercase tracking-widest hover:bg-yellow-400 transition-all">
                                    Simpan Sewa Group
                                </button>
                            </form>
                        </div>
                    </div>

                    <div class="mt-6 bg-green-500/10 border border-green-500/20 rounded-2xl p-4">
                        <p class="text-[10px] font-black text-green-500 uppercase tracking-widest mb-2">Placeholder Pesan</p>
                        <div class="space-y-2 text-xs text-gray-400">
                            <p><span class="font-mono text-green-500">@user</span> = nama atau mention user</p>
                            <p><span class="font-mono text-green-500">@grup</span> = nama group</p>
                            <p><span class="font-mono text-green-500">@desc</span> = deskripsi group</p>
                        </div>
                    </div>
                </section>

                <section class="lg:col-span-8 glass p-5 md:p-8 rounded-2xl md:rounded-[32px] border border-white/10 popup-float" style="animation-delay: 100ms;">
                    <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 pb-5 border-b border-white/5 gap-4">
                        <div class="flex items-center gap-3">
                            <div class="w-11 h-11 bg-blue-500/20 rounded-2xl flex items-center justify-center text-blue-400 text-xl shrink-0">
                                <i class="bi bi-sliders"></i>
                            </div>
                            <div>
                                <h4 id="settings-panel-title" class="text-lg font-extrabold text-white">Setting Group</h4>
                                <p id="settings-panel-subtitle" class="text-xs text-gray-500">Aktifkan fitur dan sesuaikan pesan welcome/goodbye.</p>
                            </div>
                        </div>
                        <button type="button" id="reload-groups-btn" class="px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-xs font-bold text-gray-400 hover:text-white hover:bg-white/10 transition-all">
                            <i class="bi bi-arrow-clockwise mr-1"></i>
                            Refresh
                        </button>
                    </div>

                    <form id="group-settings-form" class="space-y-8">
                        <div id="group-empty-state" class="py-16 text-center">
                            <div class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mx-auto mb-4 text-gray-500 text-2xl">
                                <i class="bi bi-chat-square-dots"></i>
                            </div>
                            <p class="text-sm font-bold text-white">Pilih group terlebih dahulu</p>
                            <p class="text-xs text-gray-500 mt-2">Pengaturan akan muncul setelah group dipilih.</p>
                        </div>

                        <div id="group-settings-content" class="hidden space-y-8">
                            <div>
                                <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-4">Feature Toggles</p>
                                <div id="group-feature-grid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3">
                                    <% const features = [
                                        { id: 'chatbot_grup', label: 'Izinkan Bot Pada Grup', icon: 'bi bi-chat-dots' },
                                        { id: 'auto_ai_grup', label: 'AI Group', icon: 'bi-stars' },
                                        { id: 'goodbye', label: 'Goodbye', icon: 'bi-door-open' },
                                        { id: 'welcome', label: 'Welcome', icon: 'bi-person-plus' }
                                    ]; %>
                                    <% features.forEach(feature => { %>
                                        <label class="feature-toggle relative flex items-center cursor-pointer group">
                                            <input type="checkbox" name="<%= feature.id %>" class="sr-only">
                                            <div class="feature-card w-full min-h-[58px] rounded-2xl border border-white/5 bg-white/5 transition-all px-4 py-3 flex items-center justify-between gap-3">
                                                <div class="flex items-center gap-3 min-w-0">
                                                    <i class="feature-icon bi <%= feature.icon %> text-gray-500 transition-colors"></i>
                                                    <span class="feature-label text-xs font-bold text-gray-400 group-hover:text-white transition-colors"><%= feature.label %></span>
                                                </div>
                                                <span class="feature-switch w-9 h-5 rounded-full bg-black/30 border border-white/10 relative shrink-0 transition-all">
                                                    <span class="feature-knob absolute w-3.5 h-3.5 rounded-full bg-gray-500 left-0.5 top-0.5 transition-transform"></span>
                                                </span>
                                            </div>
                                        </label>
                                    <% }) %>
                                </div>
                            </div>

                            <!-- Welcome Design Selector -->
                            <div>
                                <div class="flex items-center justify-between mb-4">
                                    <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Welcome Design</p>
                                    <span class="text-[10px] text-green-500 font-bold">Pilih tampilan gambar welcome</span>
                                </div>
                                <div class="grid grid-cols-2 xl:grid-cols-4 gap-3" id="welcome-design-grid">
                                    <label class="welcome-design-option relative cursor-pointer group">
                                        <input type="radio" name="welcome_design" value="design1" class="sr-only peer" checked>
                                        <div class="overflow-hidden rounded-2xl border-2 border-white/10 peer-checked:border-green-500 bg-white/5 peer-checked:bg-green-500/5 hover:border-white/25 transition-all">
                                            <div class="relative w-full" style="padding-bottom:56%">
                                                <img src="/img/welcome-example1.jpg" alt="Design 1" class="absolute inset-0 w-full h-full object-cover opacity-75 group-hover:opacity-100 transition-opacity">
                                                <div class="absolute top-2 right-2 w-5 h-5 rounded-full bg-green-500 items-center justify-center shadow-lg check-badge hidden peer-checked:flex">
                                                    <i class="bi bi-check text-black text-xs font-black"></i>
                                                </div>
                                            </div>
                                            <div class="px-3 py-2 flex items-center justify-between">
                                                <span class="text-xs font-bold text-gray-400 group-hover:text-white peer-checked:text-green-500 transition-colors">Design 1</span>
                                                <span class="radio-dot w-4 h-4 rounded-full border-2 border-white/20 peer-checked:border-green-500 bg-transparent flex items-center justify-center transition-all">
                                                    <span class="w-2 h-2 rounded-full bg-green-500 hidden peer-checked:block"></span>
                                                </span>
                                            </div>
                                        </div>
                                    </label>
                                    <label class="welcome-design-option relative cursor-pointer group">
                                        <input type="radio" name="welcome_design" value="design2" class="sr-only peer">
                                        <div class="overflow-hidden rounded-2xl border-2 border-white/10 peer-checked:border-green-500 bg-white/5 peer-checked:bg-green-500/5 hover:border-white/25 transition-all">
                                            <div class="relative w-full" style="padding-bottom:56%">
                                                <img src="/img/welcome-example2.png" alt="Design 2" class="absolute inset-0 w-full h-full object-cover opacity-75 group-hover:opacity-100 transition-opacity">
                                            </div>
                                            <div class="px-3 py-2 flex items-center justify-between">
                                                <span class="text-xs font-bold text-gray-400 group-hover:text-white peer-checked:text-green-500 transition-colors">Design 2</span>
                                                <span class="radio-dot w-4 h-4 rounded-full border-2 border-white/20 peer-checked:border-green-500 bg-transparent flex items-center justify-center transition-all">
                                                    <span class="w-2 h-2 rounded-full bg-green-500 hidden peer-checked:block"></span>
                                                </span>
                                            </div>
                                        </div>
                                    </label>
                                    <label class="welcome-design-option relative cursor-pointer group">
                                        <input type="radio" name="welcome_design" value="design3" class="sr-only peer">
                                        <div class="overflow-hidden rounded-2xl border-2 border-white/10 peer-checked:border-green-500 bg-white/5 peer-checked:bg-green-500/5 hover:border-white/25 transition-all">
                                            <div class="relative w-full" style="padding-bottom:56%">
                                                <img src="/img/welcome-example3.png" alt="Design 3" class="absolute inset-0 w-full h-full object-cover opacity-75 group-hover:opacity-100 transition-opacity">
                                            </div>
                                            <div class="px-3 py-2 flex items-center justify-between">
                                                <span class="text-xs font-bold text-gray-400 group-hover:text-white peer-checked:text-green-500 transition-colors">Design 3</span>
                                                <span class="radio-dot w-4 h-4 rounded-full border-2 border-white/20 peer-checked:border-green-500 bg-transparent flex items-center justify-center transition-all">
                                                    <span class="w-2 h-2 rounded-full bg-green-500 hidden peer-checked:block"></span>
                                                </span>
                                            </div>
                                        </div>
                                    </label>
                                    <label class="welcome-design-option relative cursor-pointer group">
                                        <input type="radio" name="welcome_design" value="design4" class="sr-only peer">
                                        <div class="overflow-hidden rounded-2xl border-2 border-white/10 peer-checked:border-green-500 bg-white/5 peer-checked:bg-green-500/5 hover:border-white/25 transition-all">
                                            <div class="relative w-full" style="padding-bottom:56%">
                                                <img src="/img/welcome-example4.jpg" alt="Design 4" class="absolute inset-0 w-full h-full object-cover opacity-75 group-hover:opacity-100 transition-opacity">
                                            </div>
                                            <div class="px-3 py-2 flex items-center justify-between">
                                                <span class="text-xs font-bold text-gray-400 group-hover:text-white peer-checked:text-green-500 transition-colors">Design 4</span>
                                                <span class="radio-dot w-4 h-4 rounded-full border-2 border-white/20 peer-checked:border-green-500 bg-transparent flex items-center justify-center transition-all">
                                                    <span class="w-2 h-2 rounded-full bg-green-500 hidden peer-checked:block"></span>
                                                </span>
                                            </div>
                                        </div>
                                    </label>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 xl:grid-cols-2 gap-5">
                                <div>
                                    <div class="flex items-center justify-between mb-3">
                                        <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Set Welcome</label>
                                        <span class="text-[10px] text-green-500 font-bold">Saat user masuk</span>
                                    </div>
                                    <textarea name="welcome_text" class="auth-input w-full min-h-[180px] py-4 px-4 rounded-2xl text-sm leading-relaxed" placeholder="Halo @user, selamat datang di @grup&#10;&#10;@desc"></textarea>
                                </div>
                                <div>
                                    <div class="flex items-center justify-between mb-3">
                                        <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Set Goodbye</label>
                                        <span class="text-[10px] text-red-400 font-bold">Saat user keluar</span>
                                    </div>
                                    <textarea name="goodbye_text" class="auth-input w-full min-h-[180px] py-4 px-4 rounded-2xl text-sm leading-relaxed" placeholder="Dadah @user dari @grup"></textarea>
                                </div>
                            </div>

                            <div class="pt-6 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-4">
                                <p class="text-xs text-gray-500 leading-relaxed">
                                    Setting disimpan pada <span class="font-mono text-green-500">database.json</span> key group dan file welcome/goodbye session bot.
                                </p>
                                <button type="submit" id="save-group-settings-btn" class="w-full md:w-auto px-8 py-4 rounded-2xl bg-green-500 text-black text-xs font-extrabold uppercase tracking-widest hover:bg-green-400 active:scale-[0.99] transition-all">
                                    <i class="bi bi-save mr-2"></i>
                                    Simpan Setting Group
                                </button>
                            </div>
                        </div>
                    </form>
                </section>
            </div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const groupSelect = document.getElementById('group-select');
                const statusBadge = document.getElementById('group-bot-status');
                const reloadBtn = document.getElementById('reload-groups-btn');
                const form = document.getElementById('group-settings-form');
                const emptyState = document.getElementById('group-empty-state');
                const content = document.getElementById('group-settings-content');
                const selectedInfo = document.getElementById('selected-group-info');
                const groupName = document.getElementById('group-name');
                const groupIdText = document.getElementById('group-id');
                const groupDesc = document.getElementById('group-desc');
                const saveBtn = document.getElementById('save-group-settings-btn');
                const groupRentalStatus = document.getElementById('group-rental-status');
                const rentalToggle = document.getElementById('rental-toggle');
                const rentalToggleIcon = document.getElementById('rental-toggle-icon');
                const rentalPanel = document.getElementById('rental-panel');
                const rentalForm = document.getElementById('group-rental-form');
                const rentalPreview = document.getElementById('rental-preview');
                const saveRentalBtn = document.getElementById('save-rental-btn');
                const customDateWrap = document.getElementById('custom-date-wrap');
                const settingsPanelTitle = document.getElementById('settings-panel-title');
                const settingsPanelSubtitle = document.getElementById('settings-panel-subtitle');
                let groups = [];
                let currentSettings = {};
                let rentalPreviewGroup = null;

                const featureKeys = ['chatbot_grup', 'auto_ai_grup', 'goodbye', 'welcome'];

                function escapeHtml(value) {
                    return String(value || '').replace(/[&<>"']/g, (char) => ({
                        '&': '&amp;',
                        '<': '&lt;',
                        '>': '&gt;',
                        '"': '&quot;',
                        "'": '&#39;'
                    }[char]));
                }

                function setStatus(text, type = 'warning') {
                    const variants = {
                        success: 'bg-green-500/10 border-green-500/20 text-green-500',
                        warning: 'bg-yellow-500/10 border-yellow-500/20 text-yellow-500',
                        error: 'bg-red-500/10 border-red-500/20 text-red-500'
                    };
                    statusBadge.className = `px-4 py-1.5 rounded-full border text-xs font-bold flex items-center gap-2 ${variants[type] || variants.warning}`;
                    statusBadge.innerHTML = `<i class="bi ${type === 'success' ? 'bi-check-circle' : type === 'error' ? 'bi-x-circle' : 'bi-hourglass-split'}"></i>${text}`;
                }

                function formatRentalDate(value) {
                    if (!value) return '-';
                    return new Date(value).toLocaleDateString('id-ID', {
                        day: '2-digit',
                        month: 'long',
                        year: 'numeric'
                    });
                }

                function updateRentalStatus(sewaGroup) {
                    const rental = sewaGroup || {};
                    const isActive = rental.enabled && rental.expired_at && new Date(rental.expired_at) > new Date();
                    if (!groupRentalStatus) return;
                    if (!isActive) {
                        groupRentalStatus.className = 'mt-4 rounded-xl bg-black/20 border border-white/5 px-3 py-2 text-xs text-gray-400';
                        groupRentalStatus.innerHTML = '<i class="bi bi-info-circle mr-1"></i> Group tidak disewakan';
                        return;
                    }

                    groupRentalStatus.className = 'mt-4 rounded-xl bg-yellow-500/10 border border-yellow-500/20 px-3 py-2 text-xs text-yellow-500';
                    groupRentalStatus.innerHTML = `<i class="bi bi-calendar2-check mr-1"></i> Masa aktif sampai <span class="font-extrabold">${formatRentalDate(rental.expired_at)}</span>`;
                }

                function setRentalMode(isOpen) {
                    rentalPanel?.classList.toggle('hidden', !isOpen);
                    rentalToggleIcon?.classList.toggle('rotate-180', isOpen);
                    if (settingsPanelTitle) settingsPanelTitle.textContent = isOpen ? 'Sewa Bot Untuk Group' : 'Setting Group';
                    if (settingsPanelSubtitle) {
                        settingsPanelSubtitle.textContent = isOpen
                            ? 'Atur URL group dan durasi masa aktif bot di group tersebut.'
                            : 'Aktifkan fitur dan sesuaikan pesan welcome/goodbye.';
                    }
                }

                function syncRentalForm(sewaGroup = {}) {
                    if (!rentalForm) return;
                    rentalPreviewGroup = null;
                    rentalForm.group_url.value = sewaGroup.group_url || '';
                    rentalForm.group_name.value = sewaGroup.group_name || '';
                    rentalPreview.textContent = sewaGroup.group_name
                        ? `Group terdeteksi: ${sewaGroup.group_name}`
                        : 'Masukkan URL invite untuk mengambil nama group.';
                    const duration = ['7', '15', '30', 'custom'].includes(sewaGroup.duration_type) ? sewaGroup.duration_type : '7';
                    const durationInput = rentalForm.querySelector(`input[name="duration_type"][value="${duration}"]`);
                    if (durationInput) durationInput.checked = true;
                    if (sewaGroup.expired_at && duration === 'custom') {
                        rentalForm.custom_date.value = new Date(sewaGroup.expired_at).toISOString().slice(0, 10);
                    }
                    customDateWrap?.classList.toggle('hidden', duration !== 'custom');
                }

                async function loadGroups() {
                    setStatus('Loading session bot', 'warning');
                    groupSelect.innerHTML = '<option value="">Memuat daftar group...</option>';
                    groupSelect.disabled = true;
                    content.classList.add('hidden');
                    emptyState.classList.remove('hidden');

                    try {
                        const response = await fetch('/api/bot/groups');
                        const result = await response.json();
                        if (!result.success) throw new Error(result.error || 'Gagal mengambil group');

                        groups = result.groups || [];
                        groupSelect.innerHTML = groups.length
                            ? '<option value="">Pilih group...</option>' + groups.map(group => `<option value="${escapeHtml(group.id)}">${escapeHtml(group.subject)} (${group.size || 0})</option>`).join('')
                            : '<option value="">Bot belum tergabung ke group</option>';
                        groupSelect.disabled = !groups.length;
                        setStatus(`Bot ${result.botNumber} connected`, 'success');
                    } catch (err) {
                        groups = [];
                        groupSelect.innerHTML = `<option value="">${err.message}</option>`;
                        setStatus(err.message, 'error');
                    }
                }

                async function selectGroupById(groupId) {
                    if (!groupId) return false;
                    const exists = groups.some(group => group.id === groupId);
                    if (!exists) return false;
                    groupSelect.value = groupId;
                    await loadGroupSettings(groupId);
                    return true;
                }

                async function loadGroupSettings(groupId) {
                    if (!groupId) {
                        selectedInfo.classList.add('hidden');
                        content.classList.add('hidden');
                        emptyState.classList.remove('hidden');
                        currentSettings = {};
                        updateRentalStatus(null);
                        syncRentalForm({});
                        return;
                    }

                    const selected = groups.find(group => group.id === groupId);
                    if (selected) {
                        groupName.textContent = selected.subject;
                        groupIdText.textContent = selected.id;
                        groupDesc.textContent = selected.desc || 'Tidak ada deskripsi group.';
                        selectedInfo.classList.remove('hidden');
                    }

                    emptyState.innerHTML = '<div class="w-12 h-12 border-4 border-green-500 border-t-transparent rounded-full animate-spin mx-auto mb-4"></div><p class="text-gray-500 text-sm font-medium">Memuat pengaturan group...</p>';
                    emptyState.classList.remove('hidden');
                    content.classList.add('hidden');

                    try {
                        const response = await fetch(`/api/bot/group-settings/${encodeURIComponent(groupId)}`);
                        const result = await response.json();
                        if (!result.success) throw new Error(result.error || 'Gagal memuat settings');

                        const settings = result.settings || {};
                        currentSettings = settings;
                        featureKeys.forEach(key => {
                            if (form[key]) form[key].checked = !!settings[key];
                        });
                        // Restore welcome_design selection
                        const savedDesign = settings.welcome_design || 'design1';
                        const designInput = form.querySelector(`input[name="welcome_design"][value="${savedDesign}"]`);
                        if (designInput) designInput.checked = true;
                        form.welcome_text.value = settings.welcome_text || '';
                        form.goodbye_text.value = settings.goodbye_text || '';
                        updateRentalStatus(settings.sewa_group);
                        syncRentalForm(settings.sewa_group || {});

                        emptyState.classList.add('hidden');
                        content.classList.remove('hidden');
                    } catch (err) {
                        showToast(err.message, 'error');
                    }
                }

                groupSelect.addEventListener('change', () => loadGroupSettings(groupSelect.value));
                reloadBtn.addEventListener('click', loadGroups);

                rentalToggle?.addEventListener('click', () => {
                    setRentalMode(rentalPanel.classList.contains('hidden'));
                });

                rentalForm?.addEventListener('change', (event) => {
                    if (event.target.name === 'duration_type') {
                        customDateWrap?.classList.toggle('hidden', event.target.value !== 'custom');
                    }
                });

                let rentalPreviewTimer;
                rentalForm?.group_url?.addEventListener('input', () => {
                    clearTimeout(rentalPreviewTimer);
                    rentalForm.group_name.value = '';
                    rentalPreviewGroup = null;
                    const url = rentalForm.group_url.value.trim();
                    if (!url) {
                        rentalPreview.textContent = 'Masukkan URL invite untuk mengambil nama group.';
                        return;
                    }

                    rentalPreview.textContent = 'Mengecek nama group...';
                    rentalPreviewTimer = setTimeout(async () => {
                        try {
                            const response = await fetch(`/api/bot/group-invite-preview?url=${encodeURIComponent(url)}`);
                            const result = await response.json();
                            if (!result.success) throw new Error(result.error || 'Gagal mengambil nama group');
                            rentalPreviewGroup = result.group || null;
                            const detectedName = result.group?.subject || 'Group WhatsApp';
                            const detectedUrl = url;
                            const selected = result.group?.id ? await selectGroupById(result.group.id) : false;
                            rentalForm.group_url.value = detectedUrl;
                            rentalForm.group_name.value = detectedName;
                            rentalPreview.innerHTML = selected || result.group?.joined
                                ? `Group terdeteksi dan sudah dipilih: <span class="text-yellow-500 font-bold">${escapeHtml(detectedName)}</span><br><span class="text-green-500">Bot sudah ada di group ini, tinggal setup waktu sewa.</span>`
                                : `Group terdeteksi: <span class="text-yellow-500 font-bold">${escapeHtml(detectedName)}</span><br><span class="text-gray-500">Bot belum ada di group ini. Saat disimpan, bot akan join otomatis melalui URL.</span>`;
                        } catch (err) {
                            rentalPreview.textContent = err.message;
                        }
                    }, 650);
                });

                form.addEventListener('submit', async (event) => {
                    event.preventDefault();
                    const groupId = groupSelect.value;
                    if (!groupId) return showToast('Pilih group terlebih dahulu.', 'error');

                    saveBtn.disabled = true;
                    saveBtn.innerHTML = '<i class="bi bi-arrow-repeat animate-spin mr-2"></i>Menyimpan...';

                    const payload = {};
                    featureKeys.forEach(key => payload[key] = !!form[key]?.checked);
                    const designRadio = form.querySelector('input[name="welcome_design"]:checked');
                    payload.welcome_design = designRadio ? designRadio.value : 'design1';
                    payload.welcome_text = form.welcome_text.value;
                    payload.goodbye_text = form.goodbye_text.value;

                    try {
                        const response = await fetch(`/api/bot/group-settings/${encodeURIComponent(groupId)}`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });
                        const result = await response.json();
                        if (!result.success) throw new Error(result.error || 'Gagal menyimpan settings');
                        showToast(result.message || 'Pengaturan group berhasil disimpan!', 'success');
                    } catch (err) {
                        showToast(err.message, 'error');
                    } finally {
                        saveBtn.disabled = false;
                        saveBtn.innerHTML = '<i class="bi bi-save mr-2"></i>Simpan Setting Group';
                    }
                });

                rentalForm?.addEventListener('submit', async (event) => {
                    event.preventDefault();
                    const groupId = groupSelect.value || rentalPreviewGroup?.id || 'from-url';

                    saveRentalBtn.disabled = true;
                    saveRentalBtn.innerHTML = '<i class="bi bi-arrow-repeat animate-spin mr-2"></i>Menyimpan...';

                    const durationRadio = rentalForm.querySelector('input[name="duration_type"]:checked');
                    const payload = {
                        group_url: rentalForm.group_url.value,
                        group_name: rentalForm.group_name.value || groupName.textContent,
                        duration_type: durationRadio ? durationRadio.value : '7',
                        custom_date: rentalForm.custom_date.value
                    };

                    try {
                        const response = await fetch(`/api/bot/group-rental/${encodeURIComponent(groupId)}`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });
                        const result = await response.json();
                        if (!result.success) throw new Error(result.error || 'Gagal menyimpan sewa group');
                        currentSettings.sewa_group = result.sewa_group;
                        updateRentalStatus(result.sewa_group);
                        syncRentalForm(result.sewa_group);
                        if (result.groupId) {
                            await loadGroups();
                            await selectGroupById(result.groupId);
                            setRentalMode(true);
                            rentalPreview.innerHTML = `Group sewa aktif: <span class="text-yellow-500 font-bold">${escapeHtml(result.group?.subject || result.sewa_group?.group_name || 'Group WhatsApp')}</span>`;
                        }
                        showToast(result.message || 'Sewa group berhasil disimpan!', 'success');
                    } catch (err) {
                        showToast(err.message, 'error');
                    } finally {
                        saveRentalBtn.disabled = false;
                        saveRentalBtn.innerHTML = 'Simpan Sewa Group';
                    }
                });

                loadGroups();
            });
        </script>

<%- include('partials/footer') %>
