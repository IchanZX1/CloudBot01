    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Theme Toggle Logic
            const themeToggle = document.getElementById('theme-toggle');
            const iconLight = document.getElementById('theme-icon-light');
            const iconDark = document.getElementById('theme-icon-dark');
            
            let isLightMode = localStorage.getItem('theme') === 'light';
            
            const applyTheme = (light) => {
                if (light) {
                    document.body.classList.add('light-theme');
                    iconLight.classList.remove('-translate-y-10', 'opacity-0');
                    iconLight.classList.add('translate-y-0', 'opacity-100');
                    iconDark.classList.remove('translate-y-0', 'opacity-100');
                    iconDark.classList.add('translate-y-10', 'opacity-0');
                } else {
                    document.body.classList.remove('light-theme');
                    iconLight.classList.add('-translate-y-10', 'opacity-0');
                    iconLight.classList.remove('translate-y-0', 'opacity-100');
                    iconDark.classList.add('translate-y-0', 'opacity-100');
                    iconDark.classList.remove('translate-y-10', 'opacity-0');
                }
            };
            
            applyTheme(isLightMode);
            
            if (themeToggle) {
                themeToggle.addEventListener('click', () => {
                    isLightMode = !isLightMode;
                    localStorage.setItem('theme', isLightMode ? 'light' : 'dark');
                    applyTheme(isLightMode);
                });
            }

            // Desktop Thumbnail Toggle Logic
            const desktopThumbToggle = document.getElementById('desktop-thumb-toggle');
            const desktopThumbDropdown = document.getElementById('desktop-thumb-dropdown');
            const desktopThumbIcon = document.getElementById('desktop-thumb-icon');
            let isDesktopThumbOpen = false;

            if (desktopThumbToggle && desktopThumbDropdown) {
                desktopThumbToggle.addEventListener('click', (e) => {
                    e.stopPropagation();
                    isDesktopThumbOpen = !isDesktopThumbOpen;
                    if (isDesktopThumbOpen) {
                        desktopThumbDropdown.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-4');
                        desktopThumbDropdown.classList.add('opacity-100', 'translate-y-0');
                        desktopThumbIcon.classList.add('rotate-180');
                    } else {
                        desktopThumbDropdown.classList.add('opacity-0', 'pointer-events-none', '-translate-y-4');
                        desktopThumbDropdown.classList.remove('opacity-100', 'translate-y-0');
                        desktopThumbIcon.classList.remove('rotate-180');
                    }
                });

                document.addEventListener('click', (e) => {
                    if (isDesktopThumbOpen && !desktopThumbDropdown.contains(e.target) && !desktopThumbToggle.contains(e.target)) {
                        desktopThumbToggle.click();
                    }
                });
            }

            const toggleBtn = document.getElementById('mobile-menu-toggle');
            const mobileMenu = document.getElementById('mobile-menu');
            const burgerTop = document.getElementById('burger-top');
            const burgerMid = document.getElementById('burger-mid');
            const burgerBot = document.getElementById('burger-bot');
            let isOpen = false;

            if (toggleBtn && mobileMenu) {
                toggleBtn.addEventListener('click', () => {
                    isOpen = !isOpen;
                    
                    if (isOpen) {
                        // Open Menu
                        mobileMenu.classList.remove('pointer-events-none');
                        mobileMenu.classList.add('opacity-100', 'translate-x-0');
                        mobileMenu.classList.remove('opacity-0', 'translate-x-full');
                        
                        // Burger Icon Transform
                        burgerTop.classList.add('rotate-45', 'translate-y-0');
                        burgerTop.classList.remove('-translate-y-1.5');
                        burgerMid.classList.add('opacity-0', 'scale-0');
                        burgerBot.classList.add('-rotate-45', 'translate-y-0');
                        burgerBot.classList.remove('translate-y-1.5');
                    } else {
                        // Close Menu
                        mobileMenu.classList.add('pointer-events-none');
                        mobileMenu.classList.remove('opacity-100', 'translate-x-0');
                        mobileMenu.classList.add('opacity-0', 'translate-x-full');
                        
                        // Burger Icon Reset
                        burgerTop.classList.remove('rotate-45', 'translate-y-0');
                        burgerTop.classList.add('-translate-y-1.5');
                        burgerMid.classList.remove('opacity-0', 'scale-0');
                        burgerBot.classList.remove('-rotate-45', 'translate-y-0');
                        burgerBot.classList.add('translate-y-1.5');
                    }
                });

                // Close menu when clicking outside
                document.addEventListener('click', (e) => {
                    if (isOpen && !mobileMenu.contains(e.target) && !toggleBtn.contains(e.target)) {
                        toggleBtn.click();
                    }
                });
            }
        });
    </script>
