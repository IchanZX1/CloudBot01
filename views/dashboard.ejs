            <script>
                document.addEventListener('DOMContentLoaded', () => {
                    const adOverlay = document.getElementById('dashboard-ad-overlay');
                    const closeAd = document.getElementById('dashboard-ad-close');

                    function hideDashboardAd() {
                        if (!adOverlay) return;
                        adOverlay.classList.add('opacity-0', 'pointer-events-none');
                        setTimeout(() => adOverlay.remove(), 180);
                    }

                    closeAd?.addEventListener('click', hideDashboardAd);
                    document.addEventListener('keydown', (event) => {
                        if (event.key === 'Escape') hideDashboardAd();
                    });

                    // Edit Msg - Single Open Accordion (visual only, tidak mengubah data/binding/logic submit)
                    const msgAccordionItems = document.querySelectorAll('#editmsg-actual-form .accordion-item');
                    msgAccordionItems.forEach((item) => {
                        const header = item.querySelector('.accordion-header');
                        if (!header) return;

                        header.addEventListener('click', () => {
                            const wasOpen = item.classList.contains('is-open');

                            msgAccordionItems.forEach((otherItem) => {
                                otherItem.classList.remove('is-open');
                                const otherHeader = otherItem.querySelector('.accordion-header');
                                if (otherHeader) otherHeader.setAttribute('aria-expanded', 'false');
                            });

                            if (!wasOpen) {
                                item.classList.add('is-open');
                                header.setAttribute('aria-expanded', 'true');
                            }
                        });
                    });
                });
            </script>

