<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css"
    />
    <link rel="stylesheet" href="css/dashboard-new.css" type="text/css" />
    <link rel="stylesheet" href="/css/custom.css" type="text/css" />

    <title>Langganan - Soft Botz</title>

    <style>
      main.dashboard-grid {
        margin-top: 24px;
      }

      .pricing-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 24px;
      }

      .price-card {
        background: rgba(255, 255, 255, 0.03);
        border-radius: 22px;
        padding: 30px 26px 32px;
        transition: all 0.25s ease;
        position: relative;
      }

      .price-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 14px 36px rgba(130, 90, 255, 0.28);
      }

      .price-card.popular {
        outline: 2px solid rgba(130, 90, 255, 0.6);
      }

      .badge-popular {
        position: absolute;
        top: -12px;
        right: 20px;
        background: linear-gradient(135deg, #8b5cf6, #a78bfa);
        color: #fff;
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 600;
      }

      .price-card h3 {
        font-weight: 700;
        margin-bottom: 6px;
      }

      .price {
        font-size: 1.8rem;
        font-weight: 800;
        color: #a78bfa;
        margin-bottom: 8px;
      }

      .price-desc {
        font-size: 0.9rem;
        margin-bottom: 18px;
        color: #9aa0a6;
      }

      .price-card ul {
        list-style: none;
        padding: 0;
        margin: 0 0 22px;
      }

      .price-card ul li {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.9rem;
        margin-bottom: 10px;
        color: #e5e7eb;
      }

      .price-card ul li i {
        color: #8b5cf6;
      }

      .price-card ul li.off i {
        color: #ef4444;
      }

      .btn-gradient {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 14px;
        border-radius: 18px;
        font-weight: 600;
        color: #fff;
        text-decoration: none;
        background: linear-gradient(135deg, #8b5cf6, #a78bfa);
        margin-top: 14px;
      }

      body.light .price-card {
        background: #ffffff;
        color: #111827;
      }

      body.light .price-card h3 {
        color: #111827;
      }

      body.light .price {
        color: #7c3aed;
      }

      body.light .price-desc {
        color: #111827;
      }

      body.light .price-card ul li {
        color: #111827;
        font-weight: 500;
      }

      body.light .price-card ul li i {
        color: #7c3aed;
      }

      body.light .price-card ul li.off {
        color: #111827;
        opacity: 0.85;
      }

      body.light .price-card ul li.off i {
        color: #ef4444;
      }

      .price-card ul li {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .price-card ul li i {
        width: 22px;
        min-width: 22px;
        text-align: center;
        font-size: 16px;
      }
    </style>
  </head>

  <body>
    <div id="tsparticles"></div>
    <div class="container">
      <nav>
        <div class="nav-left">
          <h3>Soft Botz</h3>
        </div>
        <div class="nav-right">
          <a href="/dashboard"
            ><i class="fas fa-th-large"></i><span>Dashboard</span></a
          >
          <a href="/custom"
            ><i class="fas fa-cogs"></i><span>Custom Bot</span></a
          >
          <a href="/donasi"
            ><i class="fas fa-hand-holding-heart"></i><span>Donasi</span></a
          >
          <a href="/langganan" class="active" title="Langganan"
            ><i class="fas fa-gem"></i> <span>Berlangganan</span></a
          >
          <a href="/info" title="Informasi"
            ><i class="fas fa-circle-info"></i> <span>Info</span></a
          >

          <button id="theme-toggle" class="theme-toggle-btn">
            <i class="fas fa-moon"></i>
            <i class="fas fa-sun"></i>
          </button>

          <div class="profile-dropdown">
            <img src="media/pp.jpg" class="avatar" />
            <div class="dropdown-content">
              <a href="/profile"><i class="fas fa-user-circle"></i>Profile</a>
              <a href="/report"><i class="fas fa-bug"></i> Report Bug/Error</a>
              <a href="/logout"><i class="fas fa-sign-out-alt"></i>Logout</a>
            </div>
          </div>
        </div>
      </nav>

      <main class="dashboard-grid">
        <div class="panel full-width-panel">
          <div class="panel-header">
            <h4><i class="fas fa-layer-group"></i> Paket Langganan</h4>
          </div>

          <p class="text-muted mb-4">
            Pilih paket langganan sesuai kebutuhan. Semua paket sudah termasuk
            akses full custom.
          </p>

          <div class="pricing-grid">
            <div class="price-card">
              <h3>1 Bulan</h3>
              <div class="price">Rp 15.000</div>
              <div class="price-desc">Cocok untuk coba coba</div>

              <ul>
                <li>
                  <i class="fas fa-check-circle"></i> Full akses fitur custom
                </li>
                <li><i class="fas fa-user"></i> Custom nama & nomor owner</li>
                <li><i class="fas fa-robot"></i> Custom nama bot</li>
                <li><i class="fas fa-image"></i> Custom thumbnail</li>
                <li>
                  <i class="fas fa-sticky-note"></i> Sticker packname & author
                </li>
                <li><i class="fas fa-link"></i> Link & integrasi</li>
                <li><i class="fas fa-sliders-h"></i> Atur limit bot</li>
                <li class="off"><i class="fas fa-ad"></i> Tanpa Iklan</li>
              </ul>

              <div class="d-flex flex-column gap-3 mt-3">
                <button
                  class="btn-gradient"
                  onclick="orderWA(this)"
                  data-plan="1 Bulan"
                  data-harga="15.000"
                  data-email="<%= user.email %>"
                  data-botid="<%= bot.id || 'N/A' %>"
                >
                  <i class="fab fa-whatsapp"></i> WhatsApp
                </button>
                <button class="btn-gradient" onclick="orderIG()">
                  <i class="fab fa-instagram"></i> Instagram
                </button>
              </div>
            </div>

            <div class="price-card popular">
              <div class="badge-popular">Paling Laris</div>
              <h3>2 Bulan</h3>
              <div class="price">Rp 25.000</div>
              <div class="price-desc">Lebih hemat</div>

              <ul>
                <li>
                  <i class="fas fa-check-circle"></i> Full akses fitur custom
                </li>
                <li><i class="fas fa-user"></i> Custom nama & nomor owner</li>
                <li><i class="fas fa-robot"></i> Custom nama bot</li>
                <li><i class="fas fa-image"></i> Custom thumbnail</li>
                <li>
                  <i class="fas fa-sticky-note"></i> Sticker packname & author
                </li>
                <li><i class="fas fa-link"></i> Link & integrasi</li>
                <li><i class="fas fa-sliders-h"></i> Atur limit bot</li>
                <li class="off"><i class="fas fa-ad"></i> Tanpa Iklan</li>
              </ul>

              <div class="d-flex flex-column gap-3 mt-3">
                <button
                  class="btn-gradient"
                  onclick="orderWA(this)"
                  data-plan="2 Bulan"
                  data-harga="25.000"
                  data-email="<%= user.email %>"
                  data-botid="<%= bot.id || 'N/A' %>"
                >
                  <i class="fab fa-whatsapp"></i> WhatsApp
                </button>
                <button class="btn-gradient" onclick="orderIG()">
                  <i class="fab fa-instagram"></i> Instagram
                </button>
              </div>
            </div>

            <div class="price-card">
              <h3>3 Bulan</h3>
              <div class="price">Rp 35.000</div>
              <div class="price-desc">
                Paket hemat dan cocok untuk masa aktif panjang
              </div>

              <ul>
                <li>
                  <i class="fas fa-check-circle"></i> Full akses fitur custom
                </li>
                <li><i class="fas fa-user"></i> Custom nama & nomor owner</li>
                <li><i class="fas fa-robot"></i> Custom nama bot</li>
                <li><i class="fas fa-image"></i> Custom thumbnail</li>
                <li>
                  <i class="fas fa-sticky-note"></i> Sticker packname & author
                </li>
                <li><i class="fas fa-link"></i> Link & integrasi</li>
                <li><i class="fas fa-sliders-h"></i> Atur limit bot</li>
                <li class="off"><i class="fas fa-ad"></i> Tanpa Iklan</li>
              </ul>

              <div class="d-flex flex-column gap-3 mt-3">
                <button
                  class="btn-gradient"
                  onclick="orderWA(this)"
                  data-plan="3 Bulan"
                  data-harga="35.000"
                  data-email="<%= user.email %>"
                  data-botid="<%= bot.id || 'N/A' %>"
                >
                  <i class="fab fa-whatsapp"></i> WhatsApp
                </button>
                <button class="btn-gradient" onclick="orderIG()">
                  <i class="fab fa-instagram"></i> Instagram
                </button>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/tsparticles-bundle@2.12.0/tsparticles.bundle.min.js"></script>
    <script src="/js/custom.js"></script>
  </body>
</html>
