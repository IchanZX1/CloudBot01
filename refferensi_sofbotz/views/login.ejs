<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="/css/login-light.css"
      type="text/css"
      media="all"
    />
    <title>Login To Soft Botz</title>
  </head>
  <body>
    <div id="particles-js"></div>
    <section>
      <div class="form-box">
        <div class="form-value">
          <form action="/login" method="POST">
            <h2>Login</h2>

            <% if (typeof err !== "undefined" && err && err.trim() !== "") { %>
            <div class="alert"><%= err %></div>
            <% } %>

            <div class="inputbox">
              <ion-icon name="mail-outline" class="icon-left"></ion-icon>
              <input type="email" name="email" required />
              <label>Email</label>
            </div>

            <div class="inputbox">
              <ion-icon name="lock-closed-outline" class="icon-left"></ion-icon>
              <input type="password" name="password" id="password" required />
              <label>Password</label>
              <ion-icon
                name="eye-outline"
                class="toggle-password"
                id="togglePassword"
              ></ion-icon>
            </div>

            <div class="forget">
              <label
                ><input type="checkbox" name="remember" /> Remember Me</label
              >
              <a href="/changepassword">Forget Password?</a>
            </div>

            <button type="submit">Log in</button>

            <div class="register">
              <p>Don't have an account? <a href="/register">Register</a></p>
            </div>
          </form>
        </div>
      </div>
    </section>

    <script src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script>
    <script src="/js/admin.js"></script>
    <script
      type="module"
      src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"
    ></script>
    <script
      nomodule
      src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"
    ></script>
    <script>
      const togglePassword = document.querySelector("#togglePassword");
      const password = document.querySelector("#password");

      togglePassword.addEventListener("click", function (e) {
        // toggle the type attribute
        const type =
          password.getAttribute("type") === "password" ? "text" : "password";
        password.setAttribute("type", type);
        // toggle the eye slash icon
        this.setAttribute(
          "name",
          type === "password" ? "eye-outline" : "eye-off-outline"
        );
      });
    </script>
  </body>
</html>
