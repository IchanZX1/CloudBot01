<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css"/>
<link rel="stylesheet" href="/css/admin.css"/>
<title>Admin Panel - Soft Botz</title>
</head>
<body>

<div class="admin-layout">

<div class="sidebar-overlay" id="sidebar-overlay"></div>

<aside class="sidebar" id="sidebar">
<div class="sidebar-header">
<div class="sidebar-brand">
<i class="bi bi-cpu-fill"></i>
<span>Soft Botz</span>
</div>
<button class="sidebar-close" id="sidebar-close">
<i class="bi bi-x-lg"></i>
</button>
</div>

<nav class="sidebar-menu">
<button class="menu-item active" onclick="switchSection('users')">
<i class="bi bi-people-fill"></i>
<span>User Bot</span>
</button>

<button class="menu-item" onclick="switchSection('banned')">
<i class="bi bi-slash-circle-fill"></i>
<span>Banned</span>
</button>
</nav>
</aside>

<div class="main-content">

<header class="topbar">

<div class="topbar-left">
<button class="menu-toggle" id="menu-toggle">
<i class="bi bi-list"></i>
</button>

<div class="topbar-title">
<h2>Admin Control Suite</h2>
<p>Manajemen layanan bot</p>
</div>
</div>

<div class="topbar-stats">
<div class="stat-box">
<span>Total User</span>
<b id="stat-total-user">0</b>
</div>

<div class="stat-box">
<span>Total Bot</span>
<b id="stat-total-bot">0</b>
</div>

<div class="stat-box online">
<span>Online</span>
<b id="stat-online">0</b>
</div>

<div class="stat-box offline">
<span>Offline</span>
<b id="stat-offline">0</b>
</div>
</div>

<div class="topbar-actions">
<button id="start-all-btn" class="header-btn primary">
<i class="bi bi-play-fill"></i>
Start All
</button>

<button onclick="logoutAdmin()" class="header-btn danger">
<i class="bi bi-box-arrow-left"></i>
Logout
</button>
</div>

</header>

<div class="search-section">
<div class="search-wrapper">
<i class="bi bi-search"></i>
<input type="search"
placeholder="Cari Email, Username, ID atau Nomor..."
id="search"/>
</div>
</div>

<main class="container">

<section id="users-section" class="service-container">

<% if (bot && bot.length > 0) { %>
<% bot.forEach(function(b){ %>

<div class="service-card"
data-email="<%= b.owner_email %>"
data-id="<%= b.id %>"
data-phone="<%= b.phone %>">

<div class="card-header">
<div class="user-info">

<div class="user-title">
<%= b.owner_email %>
</div>

<div class="user-sub">

<div class="username-wrap">
<i class="bi bi-person-circle username-icon"></i>
<span class="username-text">
@<%= b.username %>
</span>
</div>

<span class="role-badge <%= b.role === 'Premium' ? 'role-premium' : 'role-free' %>">
<i class="bi <%= b.role === 'Premium' ? 'bi-gem' : 'bi-person' %>"></i>
<%= b.role %>
</span>

</div>

</div>

<span class="status-dot <%= b.isactive ? 'active' : 'inactive' %>"></span>
</div>

<div class="card-body">
<div class="info-modern">

<div class="info-line">
<span class="info-key">Bot ID</span>
<span class="info-val"><%= b.id %></span>
</div>

<div class="info-line">
<span class="info-key">Nomor</span>
<span class="info-val"><%= b.phone || '-' %></span>
</div>

<div class="info-line">
<span class="info-key">Expired</span>
<span class="info-val">
<%= b.expired
? new Date(b.expired).toLocaleString("id-ID")
: "Belum diset" %>
</span>
</div>

</div>
</div>

<div class="card-footer">

<div class="expire-group">
<input type="text"
placeholder="Set Exp (7d, 1M, 1y)"
id="expInput-<%= b.id %>"/>
<button onclick="setExpire('<%= b.id %>')" class="btn-small">
<i class="bi bi-clock-history"></i>
</button>
</div>

<div class="main-actions">

<button onclick="loginAsUser('<%= b.id %>')" class="btn-flat blue">
<i class="bi bi-box-arrow-in-right"></i>
<span>Login</span>
</button>

<button id="toggleAction-<%= b.id %>"
class="btn-flat <%= b.isactive ? 'red' : 'green' %> status">
<i class="bi bi-power"></i>
<span><%= b.isactive ? 'Nonaktifkan' : 'Aktifkan' %></span>
</button>

<button id="togglePrem-<%= b.id %>"
class="btn-flat orange plan">
<i class="bi bi-gem"></i>
<span><%= b.isprem ? 'Unpremium' : 'Premium' %></span>
</button>

<button onclick="bannedAccount('<%= b.id %>', '<%= b.owner_email %>')"
class="btn-flat purple">
<i class="bi bi-hammer"></i>
<span>Banned</span>
</button>

<button onclick="deleteAccount('<%= b.id %>', '<%= b.owner_email %>')"
class="btn-flat danger">
<i class="bi bi-trash"></i>
<span>Delete</span>
</button>

</div>
</div>

</div>

<% }) %>
<% } else { %>
<p class="empty-message">Tidak ada akun ditemukan</p>
<% } %>

</section>

<section id="banned-section" class="service-container" style="display:none;">

<% if (bans && bans.length > 0) { %>
<% bans.forEach(function(b){ %>

<div class="service-card">
<div class="card-header">
<div class="user-info">
<div class="user-title"><%= b.email %></div>
</div>
</div>

<div class="card-footer">
<button onclick="unbannedAccount('<%= b.email %>')" 
class="btn-flat green">
Unban
</button>
</div>
</div>

<% }) %>
<% } else { %>
<p class="empty-message">Tidak ada akun dibanned</p>
<% } %>

</section>

</main>
</div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/admin.js"></script>

<script>
function switchSection(type){
  const users = document.getElementById("users-section")
  const banned = document.getElementById("banned-section")
  users.style.display = type === "users" ? "grid" : "none"
  banned.style.display = type === "banned" ? "grid" : "none"
}

document.addEventListener("DOMContentLoaded", () => {
  const sidebar = document.getElementById("sidebar");
  const overlay = document.getElementById("sidebar-overlay");
  const toggle = document.getElementById("menu-toggle");
  const closeBtn = document.getElementById("sidebar-close");

  if (toggle) {
    toggle.addEventListener("click", () => {
      sidebar.classList.add("open");
      overlay.classList.add("show");
    });
  }

  if (closeBtn) {
    closeBtn.addEventListener("click", () => {
      sidebar.classList.remove("open");
      overlay.classList.remove("show");
    });
  }

  if (overlay) {
    overlay.addEventListener("click", () => {
      sidebar.classList.remove("open");
      overlay.classList.remove("show");
    });
  }
});
</script>

</body>
</html>