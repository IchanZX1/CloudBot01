<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Success | Soft Botz</title>

    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: "Poppins", sans-serif;
      }

      body {
        min-height: 100vh;
        background: transparent;
      }

      /* Overlay blur transparan */
      .overlay {
        position: fixed;
        inset: 0;
        backdrop-filter: blur(14px);
        background: rgba(0, 0, 0, 0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        animation: fadeIn 0.4s ease forwards;
      }

      /* Glass card */
      .popup {
        width: 100%;
        max-width: 420px;
        padding: 42px 36px 38px;
        text-align: center;
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.14);
        backdrop-filter: blur(20px);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
        transform: translateY(18px) scale(0.94);
        opacity: 0;
        animation: popIn 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;
      }

      /* SVG checkmark */
      .checkmark {
        width: 90px;
        height: 90px;
        margin: 0 auto 20px;
      }

      .checkmark circle {
        stroke: rgba(255, 255, 255, 0.85);
        stroke-width: 5;
        fill: none;
        stroke-dasharray: 282;
        stroke-dashoffset: 282;
        animation: drawCircle 0.8s ease forwards;
      }

      .checkmark path {
        stroke: #ffffff;
        stroke-width: 5;
        fill: none;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-dasharray: 60;
        stroke-dashoffset: 60;
        animation: drawCheck 0.45s ease 0.65s forwards;
      }

      h1 {
        font-size: 1.8rem;
        font-weight: 600;
        color: #ffffff;
        margin-bottom: 8px;
        opacity: 0;
        animation: fadeUp 0.6s ease 0.85s forwards;
      }

      p {
        font-size: 0.95rem;
        color: rgba(255, 255, 255, 0.75);
        line-height: 1.7;
        opacity: 0;
        animation: fadeUp 0.6s ease 1s forwards;
      }

      .hint {
        margin-top: 22px;
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.55);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        opacity: 0;
        animation: fadeUp 0.6s ease 1.15s forwards;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }

      @keyframes popIn {
        to {
          opacity: 1;
          transform: translateY(0) scale(1);
        }
      }

      @keyframes drawCircle {
        to {
          stroke-dashoffset: 0;
        }
      }

      @keyframes drawCheck {
        to {
          stroke-dashoffset: 0;
        }
      }

      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
    </style>
  </head>
  <body>
    <div class="overlay">
      <div class="popup">
        <svg class="checkmark" viewBox="0 0 100 100">
          <circle cx="50" cy="50" r="45"></circle>
          <path d="M30 52 L45 68 L72 36"></path>
        </svg>

        <h1>Berhasil</h1>
        <p>
          Proses telah berhasil dijalankan. Sistem Soft Botz sudah menerima dan
          memproses permintaan kamu.
        </p>

        <div class="hint">
          <i class="fas fa-arrow-left"></i>
          Kembali otomatis dalam beberapa detik
        </div>
      </div>
    </div>

    <script>
      setTimeout(() => {
        history.back();
      }, 2600);
    </script>
  </body>
</html>
