<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="/css/login-light.css"
      type="text/css"
      media="all"
    />
    <title>Reset Password - Soft Botz</title>
  </head>
  <body>
    <div id="particles-js"></div>
    <section>
      <div class="form-box">
        <div class="form-value">
          <form action="/changepassword" method="POST">
            <h2>Reset Password</h2>

            <% if (typeof err !== "undefined" && err && err.trim() !== "") { %>
            <div class="alert"><%= err %></div>
            <% } %> <% if (!showOtpForm) { %>
            <!-- Step 1: Input email -->
            <div class="inputbox">
              <ion-icon name="mail-outline" class="icon-left"></ion-icon>
              <input type="email" name="email" required />
              <label>Email</label>
            </div>

            <button type="submit" name="action" value="sendOtp">
              Send OTP
            </button>

            <div class="register">
              <p>Remember your password? <a href="/login">Login</a></p>
            </div>

            <% } else { %>
            <!-- Step 2: Input OTP + New Password -->
            <input type="hidden" name="email" value="<%= email || '' %>" />

            <div class="inputbox">
              <ion-icon name="key-outline" class="icon-left"></ion-icon>
              <input type="text" name="otp" required />
              <label>OTP</label>
            </div>

            <div class="inputbox">
              <ion-icon name="lock-closed-outline" class="icon-left"></ion-icon>
              <input
                type="password"
                name="newPassword"
                id="newPassword"
                required
              />
              <label>New Password</label>
              <ion-icon
                name="eye-outline"
                class="toggle-password"
                id="togglePassword"
              ></ion-icon>
            </div>

            <button type="submit" name="action" value="resetPassword">
              Reset Password
            </button>
            <% } %>
          </form>
        </div>
      </div>
    </section>

    <script src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script>
    <script src="/js/admin.js"></script>
    <script
      type="module"
      src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"
    ></script>
    <script
      nomodule
      src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"
    ></script>
    <% if (showOtpForm) { %>
    <script>
      const togglePassword = document.querySelector("#togglePassword");
      const password = document.querySelector("#newPassword");

      togglePassword.addEventListener("click", function (e) {
        // toggle the type attribute
        const type =
          password.getAttribute("type") === "password" ? "text" : "password";
        password.setAttribute("type", type);
        // toggle the eye slash icon
        this.setAttribute(
          "name",
          type === "password" ? "eye-outline" : "eye-off-outline"
        );
      });
    </script>
    <% } %>
  </body>
</html>
