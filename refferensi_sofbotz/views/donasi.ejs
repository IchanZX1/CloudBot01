<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css"
    />
    <link rel="stylesheet" href="css/dashboard-new.css" type="text/css" />
    <link rel="stylesheet" href="/css/custom.css" type="text/css" />

    <title>Donasi - Soft Botz</title>

    <style>
      main.dashboard-grid {
        margin-top: 24px;
      }

      .donasi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 24px;
      }

      .donasi-card {
        background: rgba(255, 255, 255, 0.02);
        border-radius: 20px;
        padding: 28px 24px 30px;
        text-align: center;
        transition: all 0.25s ease;
      }

      .donasi-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(130, 90, 255, 0.25);
      }

      .donasi-card img {
        max-width: 130px;
        border-radius: 16px;
        background: #fff;
        padding: 10px;
        margin-bottom: 8px;
      }

      .donasi-card h5 {
        margin: 12px 0 6px;
        font-weight: 600;
      }

      .donasi-btn {
        margin-top: 18px;
        width: 100%;
        border-radius: 16px;
        padding: 12px;
        font-weight: 600;
        text-decoration: none;
        border: none;
      }

      .donasi-btn:hover {
        text-decoration: none;
        opacity: 0.9;
      }

      .donasi-number {
        font-size: 1.1rem;
        letter-spacing: 0.6px;
        margin-bottom: 4px;
      }

      .donasi-desc {
        margin: 22px 0 38px;
        padding: 0 6px;
      }

      .donasi-desc p {
        line-height: 1.85;
      }

      .donasi-card {
        min-height: 320px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: center;
      }

      .donasi-card h5,
      .donasi-card p {
        margin-bottom: 14px;
        text-align: center;
      }

      .donasi-card .donasi-btn {
        margin-top: 22px;
      }
    </style>
  </head>

  <body>
    <div id="tsparticles"></div>
    <div class="container">
      <nav>
        <div class="nav-left">
          <h3>Soft Botz</h3>
        </div>
        <div class="nav-right">
          <a href="/dashboard" title="Dashboard"
            ><i class="fas fa-th-large"></i> <span>Dashboard</span></a
          >
          <a href="/custom" title="Custom Bot"
            ><i class="fas fa-cogs"></i> <span>Custom Bot</span></a
          >
          <a href="/donasi" class="active" title="Berdonasi"
            ><i class="fas fa-hand-holding-heart"></i> <span>Donasi</span></a
          >
          <a href="/langganan" title="Langganan"
            ><i class="fas fa-gem"></i> <span>Berlangganan</span></a
          >
          <a href="/info" title="Informasi"
            ><i class="fas fa-circle-info"></i> <span>Info</span></a
          >
          <button id="theme-toggle" class="theme-toggle-btn">
            <i class="fas fa-moon"></i>
            <i class="fas fa-sun"></i>
          </button>

          <div class="profile-dropdown">
            <img src="media/pp.jpg" class="avatar" />
            <div class="dropdown-content">
              <a href="/profile"><i class="fas fa-user"></i>Profile</a>
              <a href="/report"><i class="fas fa-bug"></i> Report Bug/Error</a>
              <a href="/logout"><i class="fas fa-sign-out-alt"></i>Logout</a>
            </div>
          </div>
        </div>
      </nav>

      <main class="dashboard-grid">
        <div class="panel full-width-panel">
          <div class="panel-header">
            <h4><i class="fas fa-circle-dollar-to-slot"></i> Donasi</h4>
          </div>

          <div class="donasi-desc">
            <p class="text-muted">
              <i class="fas fa-gem"></i>
              Soft Botz dibangun dengan komitmen untuk memberikan layanan
              WhatsApp bot yang stabil, aman, dan mudah digunakan oleh semua
              kalangan.
              <br /><br />
              <i class="fas fa-shield-halved"></i>
              Dukungan kamu membantu kami menjaga performa server, meningkatkan
              keamanan, serta menghadirkan fitur-fitur eksklusif ke depannya.
              <br /><br />
              <i class="fas fa-heart"></i>
              Donasi tidak diwajibkan, namun sangat kami hargai. Terima kasih
              atas kepercayaan dan dukunganmu 💜
            </p>
          </div>

          <div class="donasi-grid">
            <div class="donasi-card">
              <i class="fa-brands fa-paypal fa-3x text-primary mb-2"></i>
              <h5>PayPal</h5>
              <h5 class="text-muted">Donasi via PayPal</h5>
              <a
                href="https://www.paypal.me/DrizDimzz"
                target="_blank"
                class="btn btn-save donasi-btn"
              >
                Donasi PayPal
              </a>
            </div>

            <div class="donasi-card">
              <img src="https://pomf2.lain.la/f/u06cys3h.jpg" alt="QRIS" />
              <h5>QRIS</h5>
              <h5 class="text-muted">Scan QR untuk donasi</h5>
              <a
                href="https://pomf2.lain.la/f/u06cys3h.jpg"
                target="_blank"
                class="btn btn-save donasi-btn"
              >
                Lihat QRIS
              </a>
            </div>

            <div class="donasi-card">
              <i class="bi bi-wallet2 fs-1 text-info mb-2"></i>
              <h5>DANA</h5>
              <p class="donasi-number">089603732786</p>
              <button class="btn btn-save donasi-btn" onclick="copyDana()">
                Salin Nomor DANA
              </button>
            </div>
          </div>
        </div>
      </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/tsparticles-bundle@2.12.0/tsparticles.bundle.min.js"></script>
    <script src="/js/custom.js"></script>

    <script>
      function copyDana() {
        navigator.clipboard.writeText("089603732786").then(() => {
          alert("Nomor DANA berhasil disalin");
        });
      }
    </script>
  </body>
</html>
