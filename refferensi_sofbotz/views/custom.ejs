<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="css/dashboard-new.css" type="text/css" media="all" />
    <link rel="stylesheet" href="/css/custom.css" type="text/css" media="all" />
    <title>Custom Bot - Soft Botz</title>
  </head>

  <body>
    <div id="tsparticles"></div>
    <div class="container">

      <nav>
        <div class="nav-left">
          <h3>Soft Botz</h3>
        </div>
        <div class="nav-right">
          <a href="/dashboard" title="Dashboard"><i class="fas fa-th-large"></i> <span>Dashboard</span></a>
                <a href="/custom" class="active" title="Custom Bot"><i class="fas fa-cogs"></i> <span>Custom Bot</span></a>
                <a href="/donasi" title="Berdonasi"><i class="fas fa-hand-holding-heart"></i> <span>Donasi</span></a>
                <a href="/langganan" title="Langganan"><i class="fas fa-gem"></i> <span>Berlangganan</span></a>
                <a href="/info" title="Informasi"><i class="fas fa-circle-info"></i> <span>Info</span></a>
          <button id="theme-toggle" class="theme-toggle-btn" title="Toggle Theme">
              <i class="fas fa-moon"></i>
              <i class="fas fa-sun"></i>
          </button>
          <div class="profile-dropdown">
              <img src="media/pp.jpg" alt="Avatar" class="avatar">
              <div class="dropdown-content">
                  <a href="/profile"><i class="fas fa-user"></i> Profile</a>
                  <a href="/report"><i class="fas fa-bug"></i> Report Bug/Error</a>
                  <a href="/logout"><i class="fas fa-sign-out-alt"></i> Log out</a>
              </div>
          </div>
        </div>
      </nav>

      <main class="dashboard-grid">
         <% if (typeof bot !== 'undefined' && bot) { %>

        <div class="panel">
          <form method="post" action="thumbnail" enctype="multipart/form-data">
            <div class="panel-header">
              <h4><i class="fas fa-image"></i> Thumbnail Bot</h4>
            </div><% if (bot.thumbnail) { %>
            <div class="mb-3">
              <img src="/thumbnail" width="100%" alt="thumbnail">
            </div><% } %>
            <div class="mb-3">
              <div class="upload-wrapper">
                <input type="file" name="thumbnail" id="thumbnail" accept="image/*" />
                <label for="thumbnail" class="upload-btn">Choose File</label>
                <span id="file-chosen" class="file-chosen">No file chosen</span>
              </div>
            </div>
            <button class="btn btn-save" type="submit">Save Thumbnail</button>
          </form>
        </div>

        <div class="panel full-width-panel">
          <form method="post">
            <div class="panel-header">
              <h4><i class="fas fa-sliders-h"></i> Custom Bot Settings</h4>
            </div>
            <% if (typeof err !== 'undefined' && err) { %>
              <div class="error-message"><i class="fa fa-times-circle"></i> <%= err %></div>
            <% } %>
            <%
              const now = new Date();
              const expired = new Date(bot.expired);
              const diffDays = Math.ceil((expired - now) / (1000 * 60 * 60 * 24));
              const isTrial = diffDays <= 7;
            %>
            <% if (isTrial) { %>
              <div class="trial-warning"><i class="fa fa-exclamation-triangle"></i> Kamu adalah <strong>User Trial</strong>. Upgrade untuk membuka semua fitur.</div>
            <% } %>
            <div class="form-grid">
              <div class="mb-3">
                <label for="botname" class="form-label">Bot Name<span>*</span></label>
                <input type="text" class="form-control" placeholder="Bot" name="botName" id="botname" value="<%= bot.botname %>" required />
              </div>
              <div class="mb-3">
                <label for="ownername" class="form-label">Owner Name<span>*</span></label>
                <input type="text" class="form-control" placeholder="Dimzz" name="owner" id="ownername" value="<%= bot.owner %>" required />
              </div>
              <div class="mb-3">
                <label for="ownernum" class="form-label">Owner Number<span>*</span></label>
                <input type="number" class="form-control" placeholder="6282133394459" name="ownernum" id="ownernum" value="<%= bot.ownernum %>" required />
              </div>
              <div class="mb-3">
                <label for="botnumber" class="form-label">Bot Number<span>*</span></label>
                <input type="number" class="form-control" placeholder="6282133394459" name="phone" id="botnumber" value="<%= bot.phone %>" required />
              </div>
              <div class="mb-3">
                <label for="limit" class="form-label">Limit<span>*</span></label>
                <input type="number" class="form-control" placeholder="999" name="limit" id="limit" value="<%= bot.limit_value %>" required max="999" />
              </div>
              <div class="mb-3">
                <label for="packname" class="form-label locked-label">Packname Sticker<span>*</span><% if (isTrial) { %><i class="bi bi-lock-fill lock"></i><% } %></label>
                <div class="tooltip">
                  <input type="text" class="form-control <%= isTrial ? 'readonly' : '' %>" placeholder="MyStickers" name="stickerPackage" id="packname" value="<%= isTrial ? defaults.stickerPackage : bot.sticker_package %>" <%= isTrial ? 'readonly' : '' %> required />
                  <% if (isTrial) { %><span class="tooltiptext">Fitur ini dikunci untuk trial</span><% } %>
                </div>
              </div>
              <div class="mb-3">
                <label for="stauthor" class="form-label locked-label">Author Sticker<span>*</span><% if (isTrial) { %><i class="bi bi-lock-fill lock"></i><% } %></label>
                <div class="tooltip">
                  <input type="text" class="form-control <%= isTrial ? 'readonly' : '' %>" placeholder="Soft Botz" name="stickerAuthor" id="stauthor" value="<%= isTrial ? defaults.stickerAuthor : bot.sticker_author %>" <%= isTrial ? 'readonly' : '' %> required />
                  <% if (isTrial) { %><span class="tooltiptext">Fitur ini dikunci untuk trial</span><% } %>
                </div>
              </div>
              <div class="mb-3 full-width">
                <label for="gc" class="form-label locked-label">Group Link<span>*</span><% if (isTrial) { %><i class="bi bi-lock-fill lock"></i><% } %></label>
                <div class="tooltip">
                  <input type="text" class="form-control <%= isTrial ? 'readonly' : '' %>" placeholder="https://chat.whatsapp.com/..." name="gc" id="gc" value="<%= isTrial ? defaults.gc : bot.gc_link %>" <%= isTrial ? 'readonly' : '' %> required />
                  <% if (isTrial) { %><span class="tooltiptext">Fitur ini dikunci untuk trial</span><% } %>
                </div>
              </div>
              <div class="mb-3 full-width">
                <label for="channel" class="form-label locked-label">Channel Link<span>*</span><% if (isTrial) { %><i class="bi bi-lock-fill lock"></i><% } %></label>
                <div class="tooltip">
                  <input type="text" class="form-control <%= isTrial ? 'readonly' : '' %>" placeholder="https://whatsapp.com/channel/..." name="channel" id="channel" value="<%= isTrial ? defaults.channel : bot.channel_link %>" <%= isTrial ? 'readonly' : '' %> required />
                  <% if (isTrial) { %><span class="tooltiptext">Fitur ini dikunci untuk trial</span><% } %>
                </div>
              </div>
              <div class="mb-3 full-width">
                <label class="form-label locked-label">
                  <% if (isTrial) { %> Pengaturan Fitur <i class="bi bi-lock-fill lock"></i> <% } else { %> Pengaturan Fitur, Auto Typing Dan Record Jangan Di Aktifkan Semua! <% } %>
                </label>
                <div class="feature-box">
                  <label class="feature-item"><input type="checkbox" name="disableMenfess" value="true" <%= bot.global_disabled?.menfess ? "checked" : "" %> <%= isTrial ? "disabled" : "" %>/><span>Nonaktifkan Menfess</span></label>
                  <label class="feature-item"><input type="checkbox" name="disableConfess" value="true" <%= bot.global_disabled?.confess ? "checked" : "" %> <%= isTrial ? "disabled" : "" %>/><span>Nonaktifkan Confess</span></label>
                  <label class="feature-item"><input type="checkbox" name="disableTyping" value="true" <%= bot.global_disabled?.autoTyping ? "checked" : "" %> <%= isTrial ? "disabled" : "" %>/><span>Nonaktifkan Auto Typing</span></label>
                  <label class="feature-item"><input type="checkbox" name="disableRecord" value="true" <%= bot.global_disabled?.autoRecord ? "checked" : "" %> <%= isTrial ? "disabled" : "" %>/><span>Nonaktifkan Auto Record</span></label>
                  <label class="feature-item"><input type="checkbox" name="disableOnline" value="true" <%= bot.global_disabled?.online ? "checked" : "" %> <%= isTrial ? "disabled" : "" %>/><span>Nonaktifkan Online Presence</span></label>
                </div>
                <% if (isTrial) { %><span class="tooltiptext">Fitur ini dikunci untuk trial</span><% } %>
              </div>
            </div>
            <button class="btn btn-save" type="submit">Save All Settings</button>
          </form>
        </div>
        <% } else { %>
          <div class="panel">
            <h4><i class="fas fa-exclamation-triangle"></i> Waduh... Terjadi Kesalahan</h4>
            <p>Gagal memuat data bot. Silakan kembali ke dashboard dan coba lagi.</p>
          </div>
        <% } %>
      </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/tsparticles-bundle@2.12.0/tsparticles.bundle.min.js"></script>
    <script src="/js/custom.js"></script>
    </body>
</html>