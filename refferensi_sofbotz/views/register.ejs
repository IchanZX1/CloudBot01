<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="/css/login-light.css"
      type="text/css"
      media="all"
    />
    <title>Register To Soft Botz</title>
  </head>
  <body>
    <div id="particles-js"></div>
    <section>
      <div class="form-box">
        <div class="form-value">
          <h2>Register</h2>
          <% if (typeof err !== "undefined" && err && err.trim() !== "") { %>
          <div class="alert"><%= err %></div>
          <% } %>

          <form id="registerForm" action="/register" method="post">
            <!-- Username -->
            <div class="inputbox">
              <ion-icon name="person-outline" class="icon-left"></ion-icon>
              <input type="text" name="username" id="username" required />
              <label for="username">Username</label>
            </div>

            <!-- Email -->
            <div class="inputbox">
              <ion-icon name="mail-outline" class="icon-left"></ion-icon>
              <input type="email" name="email" id="email" required />
              <label for="email">Email</label>
            </div>

            <!-- Password -->
            <div class="inputbox">
              <ion-icon name="lock-closed-outline" class="icon-left"></ion-icon>
              <input type="password" name="password" id="password" required />
              <label for="password">Password</label>
              <ion-icon
                name="eye-outline"
                class="toggle-password"
                id="togglePassword"
              ></ion-icon>
            </div>

            <!-- Confirm Password -->
            <div class="inputbox">
              <ion-icon name="lock-closed-outline" class="icon-left"></ion-icon>
              <input
                type="password"
                name="confirm_password"
                id="confirm_password"
                required
              />
              <label for="confirm_password">Confirm Password</label>
              <p
                id="passwordError"
                style="
                  display: none;
                  color: #ff4d4d;
                  font-size: 13px;
                  margin-top: 5px;
                "
              >
                Passwords do not match!
              </p>
            </div>

            <!-- Checkbox -->
            <div class="forget">
              <label
                ><input type="checkbox" name="terms" required /> I agree to the
                <a href="/policy" target="_blank" style="margin-left: 5px">
                  Terms & Conditions</a
                ></label
              >
            </div>

            <!-- Button -->
            <button name="register" type="submit">Sign up</button>

            <!-- Link ke login -->
            <div class="register">
              <p>Already have an account? <a href="/login">Login</a></p>
            </div>
          </form>
        </div>
      </div>
    </section>

    <script src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script>
    <script src="/js/admin.js"></script>
    <script
      type="module"
      src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"
    ></script>
    <script
      nomodule
      src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"
    ></script>

    <script>
      const form = document.getElementById("registerForm");
      const pass = document.getElementById("password");
      const confirm = document.getElementById("confirm_password");
      const errorText = document.getElementById("passwordError");

      form.addEventListener("submit", function (e) {
        if (pass.value !== confirm.value) {
          e.preventDefault();
          errorText.style.display = "block";
          confirm.style.border = "1px solid #ff4d4d";
        } else {
          errorText.style.display = "none";
          confirm.style.border = "";
        }
      });

      const togglePassword = document.querySelector("#togglePassword");
      const password = document.querySelector("#password");

      togglePassword.addEventListener("click", function (e) {
        // toggle the type attribute
        const type =
          password.getAttribute("type") === "password" ? "text" : "password";
        password.setAttribute("type", type);
        // toggle the eye slash icon
        this.setAttribute(
          "name",
          type === "password" ? "eye-outline" : "eye-off-outline"
        );
      });

      const toggleConfirmPassword = document.querySelector(
        "#toggleConfirmPassword"
      );
      const confirmPasswordInput = document.querySelector("#confirm_password");

      toggleConfirmPassword.addEventListener("click", function (e) {
        // toggle the type attribute
        const type =
          confirmPasswordInput.getAttribute("type") === "password"
            ? "text"
            : "password";
        confirmPasswordInput.setAttribute("type", type);
        // toggle the eye slash icon
        this.setAttribute(
          "name",
          type === "password" ? "eye-outline" : "eye-off-outline"
        );
      });
    </script>
  </body>
</html>
