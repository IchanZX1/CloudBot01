<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Soft Botz</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/dashboard-new.css">
</head>
<body>
    <div id="tsparticles"></div>

    <div class="container">
        <nav>
            <div class="nav-left">
                <h3>Soft Botz</h3>
            </div>
            <div class="nav-right">
                <a href="/dashboard" class="active" title="Dashboard"><i class="fas fa-th-large"></i> <span>Dashboard</span></a>
                <a href="/custom" title="Custom Bot"><i class="fas fa-cogs"></i> <span>Custom Bot</span></a>
                <a href="/donasi" title="Berdonasi"><i class="fas fa-hand-holding-heart"></i> <span>Donasi</span></a>
                <a href="/langganan" title="Langganan"><i class="fas fa-gem"></i> <span>Berlangganan</span></a>
                <a href="/info" title="Informasi"><i class="fas fa-circle-info"></i> <span>Info</span></a>
                <button id="theme-toggle" class="theme-toggle-btn" title="Toggle Theme">
                    <i class="fas fa-moon"></i>
                    <i class="fas fa-sun"></i>
                </button>
                <div class="profile-dropdown">
                    <img src="media/pp.jpg" alt="Avatar" class="avatar">
                    <div class="dropdown-content">
                        <a href="/profile"><i class="fas fa-user"></i> Profile</a>
                        <a href="/report"><i class="fas fa-bug"></i> Report Bug/Error</a>
                        <a href="/logout"><i class="fas fa-sign-out-alt"></i> Log out</a>
                    </div>
                </div>
            </div>
        </nav>

        <main class="dashboard-grid">
            <%# Kartu Status, Expired, Bot ID, Role %>
            <div class="stat-card status">
                <div class="card-icon"><i class="fas fa-satellite-dish"></i></div>
                <div class="card-content">
                    <h5>Status</h5>
                    <h3 id="botStatus"><%= bot.status %></h3>
                </div>
            </div>
            <div class="stat-card expired">
                <div class="card-icon"><i class="fas fa-calendar-check"></i></div>
                <div class="card-content">
                    <h5>Expired At</h5>
                    <h3><%= bot.expired %></h3>
                </div>
            </div>
            <div class="stat-card bot-id copyable" id="botIdCard" title="Click to copy ID">
                <div class="card-icon"><i class="fas fa-hashtag"></i></div>
                <div class="card-content">
                    <h5>Bot ID</h5>
                    <h3 class="small-text blurred truncate" id="botIdValue"><%= bot.id %></h3>
                </div>
            </div>
            <div class="stat-card role">
                <div class="card-icon"><i class="fas fa-user-tag"></i></div>
                <div class="card-content">
                    <h5>Role</h5>
                    <% 
                        let role = bot.role;
                        if (role.includes('<') && role.includes('>')) { 
                    %>
                        <%- role %>
                    <% 
                        } else {
                            let roleLower = role.toLowerCase();
                            let badgeClass = '';
                            if (roleLower.includes('paragon')) badgeClass = 'badge-paragon';
                            else if (roleLower.includes('supreme')) badgeClass = 'badge-supreme';
                            else if (roleLower.includes('legend')) badgeClass = 'badge-legend';
                            else if (roleLower.includes('eternal mangekyou')) badgeClass = 'badge-eternal-mangekyou';
                            else badgeClass = 'badge-default';
                    %>
                        <span class="badge <%= badgeClass %>"><%= role %></span>
                    <% 
                        } 
                    %>
                </div>
            </div>

            <%# Panel Phone Number %>
<div class="panel phone-panel">
    <div class="panel-header">
        <h4><i class="fas fa-mobile-alt"></i> Bot Number</h4>
    </div>

    <div class="panel-body phone-panel-body">
        <input
            type="text"
            id="phoneInput"
            class="phone-input blurred"
            value="<%= bot.phone %>"
            readonly
            pattern="[0-9]*"
            inputmode="numeric"
        >
    </div>
</div>

            <%# Panel Control Bot %>
            <div class="panel controls-panel">
                <div class="panel-header">
                    <h4><i class="fas fa-robot"></i> Bot Control</h4>
                </div>
                <div class="panel-body">
                    <input id="controlsData" type="hidden" value="<%= bot.id %>">
                    <div class="bot-control-container">
                        <% const isOnline = bot.status.toLowerCase() === 'online' || bot.status.toLowerCase() === 'running'; %>
                        <button id="botControlBtn" class="btn btn-main-control <%= isOnline ? 'online' : '' %>">
                            <i class="fas fa-cog"></i> <%= isOnline ? 'Running' : 'Offline' %>
                        </button>
                        <div id="botControlMenu" class="bot-control-menu">
                            <button id="start" name="start" class="btn-menu-item <%= isOnline ? 'active' : '' %>" <%- isOnline ? 'disabled' : '' %>>
                                <i class="fas fa-play"></i> Start
                            </button>
                            <button id="stop" name="stop" class="btn-menu-item" <%- !isOnline ? 'disabled' : '' %>>
                                <i class="fas fa-stop"></i> Stop
                            </button>
                            <button id="reload" name="reload" class="btn-menu-item" <%- !isOnline ? 'disabled' : '' %>>
                                <i class="fas fa-sync-alt"></i> Reload
                            </button>
                            <button id="deleteSession" name="deleteSession" class="btn-menu-item btn-menu-delete">
                                <i class="fas fa-trash"></i> Delete Session
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <% if (showConnectBotSection) { %>
<div class="panel connect-panel">
<div class="panel-header">
    <h4><i class="fas fa-plug"></i> Connect Bot</h4>

    <div class="switch-container">

        <div class="checkbox-wrapper-35">
            <input
                type="checkbox"
                id="connectMethodSwitch"
                class="switch"
                checked
            >
            <label for="connectMethodSwitch">
                <span class="switch-x-text"></span>

                <span class="switch-x-toggletext">
                    <span class="switch-x-unchecked">QR</span>
                    <span class="switch-x-checked">Pair</span>
                </span>
            </label>
        </div>

        <span class="switch-text" style="display:none;"></span>
    </div>

</div>

<div class="panel-body">

    <div id="pairingCodeSection" class="connect-method-display">
        <p>Start the bot with "Pairing Code" selected. The code will appear below.</p>
        <div id="pairingCodeResult" class="result-box"></div>
    </div>

    <div id="qrCodeSection" class="connect-method-display hidden">
        <p>Start the bot with "QR Code" selected. The QR code will appear below.</p>
        <div id="qrCodeResult" class="result-box"></div>
    </div>

</div>
</div>
<% } %>

            <%# Panel Logs %>
            <div class="panel logs-panel">
                <div class="panel-header">
                    <h4><i class="fas fa-terminal"></i> Console Logs</h4>
                    <button id="copy-logs-btn" class="btn-panel-action" title="Copy Logs"><i class="fas fa-copy"></i><span>Copy</span></button>
                </div>
                <div class="panel-body">
                    <pre id="logs-container" class="logs-content"></pre>
                </div>
            </div>

            <%# Panel Tutorial %>
            <div class="panel tutorial-panel">
                 <div class="panel-header">
                    <h4><i class="fas fa-book-open"></i> Panduan Penggunaan</h4>
                </div>
                <div class="panel-body">
                    <div class="tutorial-list">
                       <a href="https://youtube.com/playlist?list=PLOesEwJIPNXg0pNbNKTi9mDbPWNsdPtqs&si=bNHMp0MzgaHOOznt" target="_blank" class="tutorial-item">
                            <div class="tutorial-icon"><i class="fas fa-qrcode"></i></div>
                            <div class="tutorial-text"><h5>Menghubungkan Ke WhatsApp</h5><p>Pelajari cara tautkan perangkat dan menjalankan bot.</p></div>
                            <div class="tutorial-action"><i class="fas fa-chevron-right"></i></div>
                        </a>
                        <a href="/#faq" target="_blank" class="tutorial-item">
                            <div class="tutorial-icon"><i class="fas fa-question-circle"></i></div>
                            <div class="tutorial-text"><h5>Pertanyaan Yang Sering Di Ajukan</h5><p>Temukan jawaban atas pertanyaan umum tentang bot.</p></div>
                            <div class="tutorial-action"><i class="fas fa-chevron-right"></i></div>
                        </a>
                        <a href="/custom" target="_blank" class="tutorial-item">
                            <div class="tutorial-icon"><i class="fas fa-sliders-h"></i></div>
                            <div class="tutorial-text"><h5>Kustomisasi Pengaturan Bot</h5><p>Ubah thumbnail, nama bot, dan fitur lainnya.</p></div>
                            <div class="tutorial-action"><i class="fas fa-chevron-right"></i></div>
                        </a>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <%# --- Tombol FAB & Popup AI Support Chat --- %>
    <button id="open-support-chat-btn" class="support-fab">
      <i class="bi bi-chat-quote-fill"></i> <%# Pastikan Bootstrap Icons sudah di-link %>
    </button>
    <div id="support-chat-popup" class="support-chat-window">
      <div class="chat-header">
        <%# [VERIFIKASI] Pastikan ikon bi-robot ada di sini %>
        <h5><i class="bi bi-robot"></i> AI Support Service</h5>
        <button id="close-support-chat-btn" class="close-btn">&times;</button>
      </div>
      <div id="support-chat-messages" class="chat-messages">
        <div class="message ai-message">
          Halo! 👋 Ada yang bisa dibantu seputar Soft Botz? Tanyakan saja di sini ya!
        </div>
      </div>
      <div class="chat-input-area">
        <form id="support-chat-form">
          <input type="text" id="support-chat-input" placeholder="Ketik Disini..." autocomplete="off">
          <button type="submit"><i class="bi bi-send-fill"></i></button>
        </form>
      </div>
    </div>
    <%# --- Akhir Tombol FAB & Popup --- %>


    <script src="https://cdn.jsdelivr.net/npm/tsparticles-bundle@2.12.0/tsparticles.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcode-generator/1.4.4/qrcode.min.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/dashboard.js"></script>
</body>
</html>