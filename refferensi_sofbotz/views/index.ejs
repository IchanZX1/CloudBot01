<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
async function loadServers() {
  try {
    const res = await fetch("/api/servers");
    const servers = await res.json();

    servers.forEach((srv, index) => {

      const card = document.querySelectorAll(".server-card")[index];
      if (!card) return;

      const percentEl = card.querySelector(".server-percent");
      const bar = card.querySelector(".server-bar-fill");
      const statusEl = card.querySelector(".server-status");
      const btn = card.querySelector(".server-btn");
      const led = card.querySelector(".server-led");

      if (srv.comingSoon) {
        percentEl.innerText = "--";
        bar.style.width = "100%";
        bar.className = "server-bar-fill bar-coming";
        statusEl.innerHTML =
          '<i class="fas fa-hourglass-half"></i> Coming Soon';
        btn.classList.add("disabled");
        led.className = "server-led led-coming";
        return;
      }

      if (srv.offline) {
        percentEl.innerText = "--";
        bar.style.width = "100%";
        bar.className = "server-bar-fill bar-offline";
        statusEl.innerHTML =
          '<i class="fas fa-plug-circle-xmark"></i> Offline';
        btn.classList.add("disabled");
        led.className = "server-led led-offline";
        return;
      }

      percentEl.innerText = srv.percent + "%";
      bar.style.width = srv.percent + "%";

      if (srv.percent < 50) {
        bar.className = "server-bar-fill bar-ok";
        statusEl.innerHTML =
          '<i class="fas fa-circle-check"></i> Slot Available';
        led.className = "server-led led-ok";
        btn.classList.remove("disabled");

      } else if (srv.percent < 80) {
        bar.className = "server-bar-fill bar-warn";
        statusEl.innerHTML =
          '<i class="fas fa-triangle-exclamation"></i> Limited Slot';
        led.className = "server-led led-warn";
        btn.classList.remove("disabled");

      } else {
        bar.className = "server-bar-fill bar-full";
        statusEl.innerHTML =
          '<i class="fas fa-circle-xmark"></i> Full';
        led.className = "server-led led-full";
        btn.classList.add("disabled");
      }

    });

  } catch (err) {
    console.error("Failed refresh server data:", err);
  }
}

loadServers();
setInterval(loadServers, 5000);
</script>
