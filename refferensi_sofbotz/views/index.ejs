<section class="hero-wrapper">
<div class="container">
<div class="hero-card">
<span class="hero-badge"><i class="fa fa-robot"></i> WhatsApp Bot Platform</span>
<h1>Bangun & Kelola Bot WhatsApp dengan Cara Profesional</h1>
<p>
Platform jadibot WhatsApp berbasis Baileys yang stabil, aman,
dan dirancang agar mudah digunakan oleh pemula maupun developer.
</p>
<div class="hero-actions">
<a href="/register" class="btn-main"><i class="fa fa-rocket"></i> Create Bot</a>
<a href="/login" class="btn-outline"><i class="fa fa-right-to-bracket"></i> Login</a>
</div>


<div class="server-grid">

<% servers.forEach((srv, i) => { %>

  <div class="server-card
    <%= srv.offline ? 'offline' : '' %>
    <%= srv.comingSoon ? 'coming-soon' : '' %>">

    <div class="server-top">
      <div class="server-title">
        <i class="fas fa-server"></i>
        <span><%= srv.name %></span>

        <!-- LED INDICATOR -->
        <span class="server-led
          <%= srv.comingSoon
            ? 'led-coming'
            : srv.offline
            ? 'led-offline'
            : srv.status === 'Available'
            ? 'led-ok'
            : srv.status === 'Limited'
            ? 'led-warn'
            : 'led-full'
          %>"
          style="animation-delay:<%= (i % 6) * 0.3 %>s">
        </span>
      </div>

      <span class="server-percent">
        <%= srv.comingSoon || srv.offline ? '--' : srv.percent + '%' %>
      </span>
    </div>

    <!-- BAR -->
    <div class="server-bar">
      <div class="server-bar-fill
        <%= srv.comingSoon
          ? 'bar-coming'
          : srv.offline
          ? 'bar-offline'
          : srv.percent < 50
          ? 'bar-ok'
          : srv.percent < 80
          ? 'bar-warn'
          : 'bar-full'
        %>"
        style="width:<%= srv.comingSoon || srv.offline ? 100 : srv.percent %>%;">
      </div>
    </div>

    <!-- BOTTOM -->
    <div class="server-bottom">
      <div class="server-status
        <%= srv.comingSoon
          ? 'status-coming'
          : srv.offline
          ? 'status-offline'
          : srv.status === 'Available'
          ? 'status-ok'
          : srv.status === 'Limited'
          ? 'status-warn'
          : 'status-full'
        %>">

        <i class="fas
          <%= srv.comingSoon
            ? 'fa-hourglass-half'
            : srv.offline
            ? 'fa-plug-circle-xmark'
            : srv.status === 'Available'
            ? 'fa-circle-check'
            : srv.status === 'Limited'
            ? 'fa-triangle-exclamation'
            : 'fa-circle-xmark'
          %>">
        </i>

        <%= srv.availability %>
      </div>

      <a href="/register"
         class="server-btn
         <%= srv.comingSoon || srv.offline || srv.status === 'Full'
           ? 'disabled'
           : ''
         %>">
        <i class="fas fa-rocket"></i>
        Create Bot
      </a>
    </div>

  </div>

<% }) %>
</div>

</div>
</div>
